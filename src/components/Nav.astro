---
const currentPath = Astro.url.pathname;
const links = [
  { href: '/services', label: 'SEO Services' },
  { href: '/google-ads', label: 'Google Ads' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/process', label: 'Process' },
  { href: '/blog', label: 'Writing' },
  { href: '/about', label: 'About' },
];
---

<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 bg-dark/95 backdrop-blur-sm transition-colors duration-300">
  <div class="mx-auto max-w-7xl px-6 flex items-center justify-between h-16">
    <a href="/" class="block" aria-label="Meridian Digital home">
      <img
        src="/logos/logo-dark-transparent.jpg"
        alt="Meridian Digital"
        class="h-8 w-auto"
        style="mix-blend-mode: screen;"
      />
    </a>

    <!-- Desktop links -->
    <div class="hidden lg:flex items-center gap-8">
      {links.map(link => (
        <a
          href={link.href}
          class:list={[
            'text-sm font-medium transition-colors',
            currentPath === link.href || currentPath === link.href + '/' || currentPath.startsWith(link.href + '/')
              ? 'text-accent'
              : 'text-body-muted hover:text-white',
          ]}
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://app.bymeridian.com/auth/register?plan=growth"
        class="ml-2 inline-flex items-center px-4 py-2 bg-accent hover:bg-accent-hover text-white text-sm font-medium rounded-lg transition-colors"
      >
        Start Free Trial
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="lg:hidden flex flex-col gap-1.5 p-2 -mr-2"
      aria-label="Toggle menu"
    >
      <span class="block w-5 h-0.5 bg-white transition-transform origin-center" id="bar1"></span>
      <span class="block w-5 h-0.5 bg-white transition-opacity" id="bar2"></span>
      <span class="block w-5 h-0.5 bg-white transition-transform origin-center" id="bar3"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="lg:hidden hidden bg-dark border-t border-dark-border">
    <div class="px-6 py-4 flex flex-col gap-4">
      {links.map(link => (
        <a
          href={link.href}
          class:list={[
            'text-sm font-medium transition-colors py-2',
            currentPath === link.href || currentPath === link.href + '/' || currentPath.startsWith(link.href + '/')
              ? 'text-accent'
              : 'text-body-muted hover:text-white',
          ]}
        >
          {link.label}
        </a>
      ))}
      <hr class="border-dark-border my-2" />
      <a
        href="https://app.bymeridian.com/auth/register?plan=growth"
        class="inline-flex items-center justify-center px-4 py-3 bg-accent hover:bg-accent-hover text-white text-sm font-medium rounded-lg transition-colors"
      >
        Start Free Trial
      </a>
      <a
        href="/agency"
        class="inline-flex items-center justify-center px-4 py-3 border border-dark-border text-body-muted hover:text-white hover:border-white/20 text-sm font-medium rounded-lg transition-colors"
      >
        Agency Services
      </a>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('main-nav')!;
  const toggle = document.getElementById('menu-toggle')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const bar1 = document.getElementById('bar1')!;
  const bar2 = document.getElementById('bar2')!;
  const bar3 = document.getElementById('bar3')!;

  // Scroll-based bg - now adds solid background on scroll
  function updateNav() {
    if (window.scrollY > 20) {
      nav.classList.add('bg-dark', 'border-b', 'border-dark-border');
      nav.classList.remove('bg-dark/95');
    } else {
      nav.classList.remove('bg-dark', 'border-b', 'border-dark-border');
      nav.classList.add('bg-dark/95');
    }
  }
  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();

  // Mobile toggle
  let open = false;
  toggle.addEventListener('click', () => {
    open = !open;
    mobileMenu.classList.toggle('hidden', !open);
    bar1.style.transform = open ? 'rotate(45deg) translate(2.5px, 2.5px)' : '';
    bar2.style.opacity = open ? '0' : '1';
    bar3.style.transform = open ? 'rotate(-45deg) translate(2.5px, -2.5px)' : '';
    if (open) nav.classList.add('bg-dark');
  });
</script>
