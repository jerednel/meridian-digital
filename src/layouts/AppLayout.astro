---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@700;800&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      * { box-sizing: border-box; }
      body {
        margin: 0;
        min-height: 100vh;
        background: #080d13;
        color: #e6edf3;
        font-family: Inter, sans-serif;
        overflow-x: hidden;
      }
      a { color: inherit; }
      .app-shell {
        min-height: 100vh;
        background: linear-gradient(180deg, #080d13 0%, #0d1117 48%, #080d13 100%);
      }
      .app-nav {
        min-height: 64px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        max-width: 1160px;
        margin: 0 auto;
        padding: 0 24px;
        border-bottom: 1px solid #30363d;
      }
      .app-brand {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        color: #e6edf3;
        font-family: "Plus Jakarta Sans", sans-serif;
        font-weight: 800;
        text-decoration: none;
      }
      .app-nav-links {
        display: flex;
        align-items: center;
        gap: 18px;
        color: #8b949e;
        font-size: 0.92rem;
      }
      .app-nav-links a,
      .app-nav-links button {
        border: 0;
        border-radius: 999px;
        background: transparent;
        color: inherit;
        font: inherit;
        text-decoration: none;
        cursor: pointer;
        padding: 7px 10px;
      }
      .app-nav-links a:hover,
      .app-nav-links button:hover { color: #fff; }
      .app-nav-links a.active {
        background: rgba(139, 233, 168, 0.1);
        color: #8be9a8;
      }
      .app-main {
        box-sizing: border-box;
        width: 100%;
        max-width: 1160px;
        margin: 0 auto;
        padding: 48px 24px 80px;
      }
      .app-kicker {
        color: #8be9a8;
        font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.78rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
      .app-title {
        margin: 12px 0 0;
        max-width: 780px;
        font-family: "Plus Jakarta Sans", sans-serif;
        font-size: clamp(2.4rem, 6vw, 4.8rem);
        line-height: 0.98;
        letter-spacing: 0;
      }
      .app-subtitle {
        max-width: 700px;
        color: #8b949e;
        font-size: 1.05rem;
        line-height: 1.75;
      }
      .app-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
        gap: 18px;
        align-items: start;
        margin-top: 28px;
      }
      .app-grid-three {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
        margin-top: 18px;
      }
      .app-card {
        max-width: 100%;
        overflow: hidden;
        border: 1px solid #30363d;
        border-radius: 8px;
        background: linear-gradient(180deg, rgba(255,255,255,0.035), rgba(255,255,255,0.012));
        padding: 22px;
      }
      .app-card h2,
      .app-card h3 {
        margin: 0;
        font-family: "Plus Jakarta Sans", sans-serif;
        letter-spacing: 0;
      }
      .app-card p,
      .app-card li,
      .app-muted {
        color: #8b949e;
        line-height: 1.65;
      }
      .app-card ul {
        display: grid;
        gap: 10px;
        margin: 16px 0 0;
        padding: 0;
        list-style: none;
      }
      .app-card li::before {
        content: "•";
        color: #8be9a8;
        margin-right: 8px;
      }
      .app-form {
        display: grid;
        gap: 14px;
      }
      .app-form label {
        display: grid;
        gap: 6px;
        color: #c9d1d9;
        font-size: 0.9rem;
        font-weight: 700;
      }
      .field-hint {
        color: #8b949e;
        font-size: 0.82rem;
        font-weight: 500;
        line-height: 1.45;
      }
      .field-hint.warning {
        color: #ffcf7a;
      }
      .app-form input,
      .app-form textarea {
        width: 100%;
        border: 1px solid #30363d;
        border-radius: 8px;
        background: rgba(8, 13, 19, 0.8);
        color: #e6edf3;
        font: inherit;
        padding: 12px 13px;
      }
      .app-form textarea {
        min-height: 120px;
        resize: vertical;
      }
      .app-form select {
        width: 100%;
        border: 1px solid #30363d;
        border-radius: 8px;
        background: rgba(8, 13, 19, 0.8);
        color: #e6edf3;
        font: inherit;
        padding: 12px 13px;
      }
      .compact-form {
        display: grid;
        grid-template-columns: minmax(220px, 1fr) auto;
        align-items: end;
      }
      .app-button,
      .app-secondary {
        min-height: 46px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        padding: 12px 16px;
        font-weight: 800;
        text-decoration: none;
        cursor: pointer;
      }
      .app-button {
        border: 0;
        background: #8be9a8;
        color: #081019;
      }
      .app-button:disabled {
        opacity: 0.62;
        cursor: wait;
      }
      .app-secondary {
        border: 1px solid rgba(143, 211, 255, 0.42);
        background: rgba(8, 16, 25, 0.66);
        color: #e6edf3;
      }
      .app-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 20px;
      }
      .section-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 12px;
      }
      .help-label {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        max-width: 100%;
      }
      .help-dot {
        flex: 0 0 auto;
        width: 18px;
        height: 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(143, 211, 255, 0.42);
        border-radius: 999px;
        background: rgba(143, 211, 255, 0.08);
        color: #8fd3ff;
        cursor: help;
        font-family: Inter, sans-serif;
        font-size: 0.72rem;
        font-weight: 900;
        line-height: 1;
        text-transform: none;
      }
      .help-tip {
        position: absolute;
        z-index: 10;
        left: 0;
        top: calc(100% + 8px);
        width: min(340px, calc(100vw - 48px));
        display: none;
        border: 1px solid rgba(143, 211, 255, 0.3);
        border-radius: 8px;
        background: #0d131b;
        box-shadow: 0 18px 44px rgba(0, 0, 0, 0.36);
        color: #c9d1d9;
        font-family: Inter, sans-serif;
        font-size: 0.84rem;
        font-weight: 500;
        line-height: 1.55;
        padding: 12px;
        text-transform: none;
      }
      .help-label:hover .help-tip,
      .help-label:focus-within .help-tip {
        display: block;
      }
      .help-label.right-tip .help-tip {
        left: auto;
        right: 0;
      }
      .help-copy {
        color: #8b949e;
        font-size: 0.86rem;
        line-height: 1.55;
        margin: 6px 0 0;
      }
      .pill {
        display: inline-flex;
        align-items: center;
        min-height: 28px;
        border: 1px solid rgba(139, 233, 168, 0.38);
        border-radius: 999px;
        padding: 4px 10px;
        color: #8be9a8;
        font-size: 0.76rem;
        font-weight: 800;
        text-transform: uppercase;
      }
      .app-status {
        display: none;
        border-radius: 8px;
        padding: 12px 14px;
        font-weight: 700;
      }
      .app-status.visible { display: block; }
      .app-status.ok {
        background: rgba(139, 233, 168, 0.12);
        border: 1px solid rgba(139, 233, 168, 0.45);
        color: #8be9a8;
      }
      .app-status.error {
        background: rgba(255, 154, 154, 0.12);
        border: 1px solid rgba(255, 154, 154, 0.45);
        color: #ff9a9a;
      }
      .brief-hero {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 24px;
        align-items: end;
        background: linear-gradient(135deg, rgba(139, 233, 168, 0.12), rgba(143, 211, 255, 0.08) 42%, rgba(255,255,255,0.02));
      }
      .brief-title {
        margin: 12px 0 0;
        max-width: 860px;
        font-family: "Plus Jakarta Sans", sans-serif;
        font-size: clamp(2rem, 4.5vw, 4.1rem);
        line-height: 1;
        letter-spacing: 0;
      }
      .brief-subtitle {
        max-width: 760px;
        color: #b4c0ca;
        font-size: 1rem;
        line-height: 1.7;
        margin-bottom: 0;
      }
      .brief-actions {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 10px;
      }
      .app-secondary.quiet {
        color: #8b949e;
      }
      .verdict-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) repeat(2, minmax(0, 0.95fr));
        gap: 14px;
        margin-top: 18px;
      }
      .verdict-card {
        min-height: 154px;
        display: grid;
        align-content: space-between;
        gap: 12px;
        border: 1px solid #30363d;
        border-radius: 8px;
        background: rgba(8, 13, 19, 0.58);
        padding: 18px;
      }
      .verdict-card.primary {
        border-color: rgba(139, 233, 168, 0.42);
        background: rgba(139, 233, 168, 0.08);
      }
      .verdict-label {
        color: #8fd3ff;
        font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.76rem;
        font-weight: 800;
        text-transform: uppercase;
      }
      .verdict-card strong {
        color: #e6edf3;
        font-family: "Plus Jakarta Sans", sans-serif;
        font-size: 1.2rem;
        line-height: 1.25;
      }
      .verdict-card p {
        margin: 0;
        color: #8b949e;
        font-weight: 700;
      }
      .brief-grid {
        grid-template-columns: minmax(0, 1.12fr) minmax(330px, 0.88fr);
      }
      .next-action-card h3 {
        margin: 10px 0 12px;
        color: #fff;
        font-size: 1.55rem;
        line-height: 1.25;
      }
      .why-box,
      .asset-why {
        display: grid;
        gap: 6px;
        border: 1px solid rgba(139, 233, 168, 0.26);
        border-radius: 8px;
        background: rgba(139, 233, 168, 0.08);
        margin-top: 16px;
        padding: 14px;
      }
      .why-box strong,
      .asset-why strong {
        color: #8be9a8;
        font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.78rem;
        text-transform: uppercase;
      }
      .why-box span,
      .asset-why span {
        color: #c9d1d9;
        line-height: 1.55;
      }
      .muted-pill {
        border-color: rgba(143, 211, 255, 0.32);
        color: #8fd3ff;
      }
      .metric {
        display: grid;
        gap: 8px;
      }
      .metric strong {
        color: #8fd3ff;
        font-size: 2rem;
        line-height: 1;
      }
      .key-value {
        display: grid;
        gap: 12px;
      }
      .key-value div {
        display: grid;
        grid-template-columns: 140px 1fr;
        gap: 14px;
        border-bottom: 1px solid rgba(48, 54, 61, 0.72);
        padding-bottom: 12px;
      }
      .key-value strong {
        align-items: center;
        color: #8fd3ff;
        font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.8rem;
        text-transform: uppercase;
      }
      .source-list,
      .stack-list,
      .prompt-grid,
      .table-list {
        display: grid;
        gap: 12px;
        margin-top: 16px;
      }
      .source-list div {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        border-bottom: 1px solid rgba(48, 54, 61, 0.72);
        padding-bottom: 10px;
        color: #8b949e;
      }
      .source-list strong {
        color: #8be9a8;
        font-size: 0.78rem;
        text-transform: uppercase;
      }
      .stack-list article {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 12px;
        border: 1px solid rgba(48, 54, 61, 0.72);
        border-radius: 8px;
        padding: 14px;
        background: rgba(8, 13, 19, 0.45);
      }
      .stack-list article:not(:has(.rank)) {
        grid-template-columns: 1fr;
      }
      .stack-list h3,
      .prompt-card p {
        margin: 0;
      }
      .stack-list p,
      .stack-list small,
      .prompt-card small,
      .table-list p,
      .table-list span {
        color: #8b949e;
        line-height: 1.55;
      }
      .rank {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 30px;
        height: 30px;
        border-radius: 999px;
        background: #8be9a8;
        color: #081019;
        font-weight: 900;
      }
      .prompt-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .prompt-card,
      .table-list div {
        border: 1px solid rgba(48, 54, 61, 0.72);
        border-radius: 8px;
        padding: 14px;
        background: rgba(8, 13, 19, 0.45);
      }
      .prompt-card span,
      .table-list span {
        display: inline-flex;
        margin-bottom: 8px;
        color: #8fd3ff;
        font-size: 0.76rem;
        font-weight: 800;
        text-transform: uppercase;
      }
      .prompt-card .help-tip,
      .table-list .help-tip,
      .source-list .help-tip,
      .key-value .help-tip {
        display: none;
        color: #c9d1d9;
        font-size: 0.84rem;
        font-weight: 500;
        text-transform: none;
      }
      .prompt-card .help-label:hover .help-tip,
      .prompt-card .help-label:focus-within .help-tip,
      .table-list .help-label:hover .help-tip,
      .table-list .help-label:focus-within .help-tip,
      .source-list .help-label:hover .help-tip,
      .source-list .help-label:focus-within .help-tip,
      .key-value .help-label:hover .help-tip,
      .key-value .help-label:focus-within .help-tip {
        display: block;
      }
      .table-list div {
        display: grid;
        grid-template-columns: 1fr auto auto;
        gap: 8px;
      }
      .table-list p {
        grid-column: 1 / -1;
        margin: 0;
      }
      .solution-assets {
        margin-top: 28px;
      }
      .asset-tabs {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 16px;
      }
      .asset-tab {
        min-height: 38px;
        border: 1px solid rgba(143, 211, 255, 0.34);
        border-radius: 999px;
        background: rgba(8, 16, 25, 0.66);
        color: #c9d1d9;
        cursor: pointer;
        font: inherit;
        font-size: 0.86rem;
        font-weight: 800;
        padding: 8px 12px;
      }
      .asset-tab.active {
        border-color: rgba(139, 233, 168, 0.52);
        background: rgba(139, 233, 168, 0.14);
        color: #8be9a8;
      }
      .asset-pane {
        display: none;
        margin-top: 16px;
      }
      .asset-pane.active {
        display: block;
      }
      .asset-status {
        color: #8be9a8;
      }
      .asset-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(300px, 0.72fr);
        gap: 16px;
        margin-top: 16px;
      }
      .asset-panel,
      .code-panel {
        min-width: 0;
        border: 1px solid rgba(48, 54, 61, 0.72);
        border-radius: 8px;
        background: rgba(8, 13, 19, 0.45);
        padding: 16px;
      }
      .asset-panel h3,
      .asset-panel h4 {
        margin: 0 0 10px;
        font-family: "Plus Jakarta Sans", sans-serif;
        letter-spacing: 0;
      }
      .asset-description,
      .asset-copy,
      .asset-section p,
      .faq-list p,
      .asset-panel li,
      .asset-panel p {
        color: #8b949e;
        line-height: 1.65;
      }
      .asset-copy {
        white-space: pre-line;
      }
      .asset-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 12px;
        color: #8fd3ff;
        font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.76rem;
        overflow-wrap: anywhere;
      }
      .asset-buttons {
        flex: 0 0 auto;
        display: inline-flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 8px;
      }
      .copy-button {
        flex: 0 0 auto;
        min-height: 32px;
        border: 1px solid rgba(143, 211, 255, 0.45);
        border-radius: 8px;
        background: rgba(143, 211, 255, 0.08);
        color: #e6edf3;
        font: inherit;
        font-family: Inter, sans-serif;
        font-size: 0.78rem;
        font-weight: 800;
        cursor: pointer;
        padding: 6px 10px;
      }
      .copy-button.agent-copy {
        border-color: rgba(139, 233, 168, 0.48);
        background: rgba(139, 233, 168, 0.12);
        color: #8be9a8;
      }
      .copy-button:disabled {
        opacity: 0.62;
        cursor: wait;
      }
      .action-log-button {
        justify-self: start;
        margin-top: 10px;
      }
      .delete-log-button {
        border-color: rgba(255, 154, 154, 0.34);
        color: #ff9a9a;
        margin-top: 8px;
      }
      .progress-card {
        margin-top: 28px;
      }
      .progress-chart {
        display: grid;
        gap: 14px;
      }
      .progress-summary {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
      }
      .progress-summary div {
        border: 1px solid rgba(48, 54, 61, 0.72);
        border-radius: 8px;
        background: rgba(8, 13, 19, 0.45);
        padding: 12px;
      }
      .progress-summary strong {
        display: block;
        color: #e6edf3;
        font-size: 1.45rem;
        line-height: 1;
      }
      .progress-summary span {
        color: #8b949e;
        font-size: 0.8rem;
        font-weight: 800;
        text-transform: uppercase;
      }
      .trend-svg {
        width: 100%;
        min-height: 220px;
        overflow: visible;
      }
      .axis {
        stroke: rgba(139, 148, 158, 0.34);
        stroke-width: 1;
      }
      .trend-line {
        fill: none;
        stroke-width: 3;
      }
      .trend-line.visibility,
      .trend-dot.visibility {
        stroke: #8be9a8;
        fill: #8be9a8;
      }
      .trend-line.citation,
      .trend-dot.citation {
        stroke: #8fd3ff;
        fill: #8fd3ff;
      }
      .trend-line.pressure,
      .trend-dot.pressure {
        stroke: #ffcf7a;
        fill: #ffcf7a;
      }
      .action-marker {
        stroke: rgba(255, 255, 255, 0.26);
        stroke-dasharray: 4 5;
      }
      .action-dot {
        fill: #f778ba;
        stroke: #0d1117;
        stroke-width: 2;
      }
      .chart-legend {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        color: #8b949e;
        font-size: 0.84rem;
        font-weight: 800;
      }
      .chart-legend span {
        display: inline-flex;
        align-items: center;
        gap: 6px;
      }
      .legend-swatch {
        width: 10px;
        height: 10px;
        display: inline-block;
        border-radius: 999px;
      }
      .legend-swatch.visibility { background: #8be9a8; }
      .legend-swatch.citation { background: #8fd3ff; }
      .legend-swatch.pressure { background: #ffcf7a; }
      .legend-swatch.action { background: #f778ba; }
      .timeline-list {
        display: grid;
        gap: 10px;
        margin-top: 16px;
      }
      .timeline-list article {
        display: grid;
        grid-template-columns: 86px 1fr;
        gap: 12px;
        border-top: 1px solid rgba(48, 54, 61, 0.72);
        padding-top: 12px;
      }
      .timeline-list article > span {
        color: #8fd3ff;
        font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.78rem;
        font-weight: 800;
        text-transform: uppercase;
      }
      .timeline-list strong {
        color: #e6edf3;
        font-family: "Plus Jakarta Sans", sans-serif;
        text-transform: capitalize;
      }
      .timeline-list p,
      .timeline-list small {
        color: #8b949e;
        display: block;
        line-height: 1.55;
        margin: 4px 0 0;
      }
      .timeline-list a {
        color: #8be9a8;
        display: inline-flex;
        font-weight: 800;
        margin-top: 6px;
      }
      .agent-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        border: 1px solid rgba(139, 233, 168, 0.24);
        border-radius: 8px;
        background: rgba(139, 233, 168, 0.08);
        color: #c9d1d9;
        font-size: 0.88rem;
        font-weight: 700;
        margin-bottom: 12px;
        padding: 12px;
      }
      .asset-section-list,
      .faq-list,
      .snippet-list {
        display: grid;
        gap: 12px;
        margin-top: 14px;
      }
      .asset-section,
      .faq-list article {
        border-top: 1px solid rgba(48, 54, 61, 0.72);
        padding-top: 12px;
      }
      .asset-table {
        display: grid;
        gap: 8px;
        margin-top: 14px;
      }
      .asset-table div {
        display: grid;
        grid-template-columns: 180px 1fr;
        gap: 12px;
        border: 1px solid rgba(48, 54, 61, 0.72);
        border-radius: 8px;
        padding: 10px;
      }
      .asset-table strong {
        color: #8be9a8;
      }
      .asset-table span {
        color: #8b949e;
        line-height: 1.55;
      }
      .asset-cta {
        border-left: 3px solid #8be9a8;
        margin-top: 16px;
        padding-left: 12px;
      }
      .code-panel {
        margin-top: 16px;
      }
      .asset-pane .code-panel {
        margin-top: 0;
      }
      .code-panel pre {
        max-height: 440px;
        overflow: auto;
        border-radius: 8px;
        background: #05080d;
        margin: 0;
        padding: 14px;
      }
      .code-panel code {
        color: #c9d1d9;
        font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.8rem;
        line-height: 1.6;
        white-space: pre;
      }
      .hidden { display: none !important; }
      .admin-drawer {
        margin-top: 28px;
      }
      .admin-drawer summary {
        color: #8b949e;
        cursor: pointer;
        font-weight: 800;
      }
      .admin-drawer .app-card {
        margin-top: 12px;
      }
      @media (max-width: 820px) {
        .app-main {
          max-width: none;
          margin: 0 auto;
          padding-left: 20px;
          padding-right: 20px;
        }
        .app-title {
          max-width: 9.5ch;
          font-size: clamp(2.35rem, 10vw, 3rem);
        }
        .app-subtitle {
          max-width: 320px;
        }
        .app-grid,
        .app-grid-three,
        .verdict-grid,
        .brief-hero {
          grid-template-columns: 1fr;
        }
        .brief-actions {
          justify-content: stretch;
        }
        .brief-actions .app-button,
        .brief-actions .app-secondary {
          width: 100%;
        }
        .compact-form {
          grid-template-columns: 1fr;
        }
        .app-nav {
          align-items: flex-start;
          flex-direction: column;
          justify-content: center;
          padding-top: 14px;
          padding-bottom: 14px;
        }
        .app-nav-links {
          flex-wrap: wrap;
        }
        .key-value div {
          grid-template-columns: 1fr;
        }
        .section-head,
        .source-list div {
          align-items: flex-start;
          flex-direction: column;
        }
        .help-label.right-tip .help-tip {
          left: 0;
          right: auto;
        }
        .prompt-grid,
        .table-list div,
        .asset-grid,
        .progress-summary,
        .asset-table div {
          grid-template-columns: 1fr;
        }
        .timeline-list article {
          grid-template-columns: 1fr;
        }
        .asset-meta {
          align-items: flex-start;
          flex-direction: column;
        }
        .asset-buttons,
        .agent-bar {
          width: 100%;
        }
        .asset-buttons,
        .agent-bar {
          flex-direction: column;
          align-items: stretch;
        }
        .copy-button {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <div class="app-shell">
      <nav class="app-nav">
        <a class="app-brand" href="/app">Meridian</a>
        <div class="app-nav-links">
          <a href="/app" data-nav-path="/app">Brief</a>
          <a href="/app/onboarding" data-nav-path="/app/onboarding">Inputs</a>
          <a href="/app#generated-assets" data-nav-path="/app#generated-assets">Assets</a>
          <a href="/app/account" data-nav-path="/app/account">Billing</a>
          <button id="logout-button" class="hidden" type="button">Log out</button>
        </div>
      </nav>
      <main class="app-main">
        <slot />
      </main>
    </div>
    <script is:inline>
      const logoutButton = document.getElementById('logout-button');
      if (logoutButton && localStorage.getItem('meridian_session')) {
        logoutButton.classList.remove('hidden');
        logoutButton.addEventListener('click', () => {
          localStorage.removeItem('meridian_session');
          window.location.href = '/app/login';
        });
      }
      document.querySelectorAll('[data-nav-path]').forEach((link) => {
        const path = link.getAttribute('href');
        if (path === window.location.pathname || (path === '/app#generated-assets' && window.location.hash === '#generated-assets')) {
          link.classList.add('active');
        }
      });
    </script>
  </body>
</html>
