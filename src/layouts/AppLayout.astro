---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@700;800&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      * { box-sizing: border-box; }
      body {
        margin: 0;
        min-height: 100vh;
        background: #080d13;
        color: #e6edf3;
        font-family: Inter, sans-serif;
        overflow-x: hidden;
      }
      a { color: inherit; }
      .app-shell {
        min-height: 100vh;
        background: linear-gradient(180deg, #080d13 0%, #0d1117 48%, #080d13 100%);
      }
      .app-nav {
        min-height: 64px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        max-width: 1160px;
        margin: 0 auto;
        padding: 0 24px;
        border-bottom: 1px solid #30363d;
      }
      .app-brand {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        color: #e6edf3;
        font-family: "Plus Jakarta Sans", sans-serif;
        font-weight: 800;
        text-decoration: none;
      }
      .app-nav-links {
        display: flex;
        align-items: center;
        gap: 18px;
        color: #8b949e;
        font-size: 0.92rem;
      }
      .app-nav-links a,
      .app-nav-links button {
        border: 0;
        background: transparent;
        color: inherit;
        font: inherit;
        text-decoration: none;
        cursor: pointer;
      }
      .app-nav-links a:hover,
      .app-nav-links button:hover { color: #fff; }
      .app-main {
        box-sizing: border-box;
        width: 100%;
        max-width: 1160px;
        margin: 0 auto;
        padding: 48px 24px 80px;
      }
      .app-kicker {
        color: #8be9a8;
        font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.78rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
      .app-title {
        margin: 12px 0 0;
        max-width: 780px;
        font-family: "Plus Jakarta Sans", sans-serif;
        font-size: clamp(2.4rem, 6vw, 4.8rem);
        line-height: 0.98;
        letter-spacing: 0;
      }
      .app-subtitle {
        max-width: 700px;
        color: #8b949e;
        font-size: 1.05rem;
        line-height: 1.75;
      }
      .app-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
        gap: 18px;
        align-items: start;
        margin-top: 28px;
      }
      .app-grid-three {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
        margin-top: 18px;
      }
      .app-card {
        max-width: 100%;
        overflow: hidden;
        border: 1px solid #30363d;
        border-radius: 8px;
        background: linear-gradient(180deg, rgba(255,255,255,0.035), rgba(255,255,255,0.012));
        padding: 22px;
      }
      .app-card h2,
      .app-card h3 {
        margin: 0;
        font-family: "Plus Jakarta Sans", sans-serif;
        letter-spacing: 0;
      }
      .app-card p,
      .app-card li,
      .app-muted {
        color: #8b949e;
        line-height: 1.65;
      }
      .app-card ul {
        display: grid;
        gap: 10px;
        margin: 16px 0 0;
        padding: 0;
        list-style: none;
      }
      .app-card li::before {
        content: "•";
        color: #8be9a8;
        margin-right: 8px;
      }
      .app-form {
        display: grid;
        gap: 14px;
      }
      .app-form label {
        display: grid;
        gap: 6px;
        color: #c9d1d9;
        font-size: 0.9rem;
        font-weight: 700;
      }
      .app-form input,
      .app-form textarea {
        width: 100%;
        border: 1px solid #30363d;
        border-radius: 8px;
        background: rgba(8, 13, 19, 0.8);
        color: #e6edf3;
        font: inherit;
        padding: 12px 13px;
      }
      .app-form textarea {
        min-height: 120px;
        resize: vertical;
      }
      .app-button,
      .app-secondary {
        min-height: 46px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        padding: 12px 16px;
        font-weight: 800;
        text-decoration: none;
        cursor: pointer;
      }
      .app-button {
        border: 0;
        background: #8be9a8;
        color: #081019;
      }
      .app-secondary {
        border: 1px solid rgba(143, 211, 255, 0.42);
        background: rgba(8, 16, 25, 0.66);
        color: #e6edf3;
      }
      .app-status {
        display: none;
        border-radius: 8px;
        padding: 12px 14px;
        font-weight: 700;
      }
      .app-status.visible { display: block; }
      .app-status.ok {
        background: rgba(139, 233, 168, 0.12);
        border: 1px solid rgba(139, 233, 168, 0.45);
        color: #8be9a8;
      }
      .app-status.error {
        background: rgba(255, 154, 154, 0.12);
        border: 1px solid rgba(255, 154, 154, 0.45);
        color: #ff9a9a;
      }
      .metric {
        display: grid;
        gap: 8px;
      }
      .metric strong {
        color: #8fd3ff;
        font-size: 2rem;
        line-height: 1;
      }
      .key-value {
        display: grid;
        gap: 12px;
      }
      .key-value div {
        display: grid;
        grid-template-columns: 140px 1fr;
        gap: 14px;
        border-bottom: 1px solid rgba(48, 54, 61, 0.72);
        padding-bottom: 12px;
      }
      .key-value strong {
        color: #8fd3ff;
        font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.8rem;
        text-transform: uppercase;
      }
      .hidden { display: none !important; }
      @media (max-width: 820px) {
        .app-main {
          max-width: 350px;
          margin: 0;
          padding-left: 20px;
          padding-right: 20px;
        }
        .app-title {
          max-width: 9.5ch;
          font-size: clamp(2.35rem, 10vw, 3rem);
        }
        .app-subtitle {
          max-width: 320px;
        }
        .app-grid,
        .app-grid-three {
          grid-template-columns: 1fr;
        }
        .app-nav {
          align-items: flex-start;
          flex-direction: column;
          justify-content: center;
          padding-top: 14px;
          padding-bottom: 14px;
        }
        .app-nav-links {
          flex-wrap: wrap;
        }
        .key-value div {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <div class="app-shell">
      <nav class="app-nav">
        <a class="app-brand" href="/app">Meridian</a>
        <div class="app-nav-links">
          <a href="/app">Dashboard</a>
          <a href="/app/onboarding">Onboarding</a>
          <a href="/app/account">Account</a>
          <a href="/ai-search">Product</a>
          <button id="logout-button" class="hidden" type="button">Log out</button>
        </div>
      </nav>
      <main class="app-main">
        <slot />
      </main>
    </div>
    <script is:inline>
      const logoutButton = document.getElementById('logout-button');
      if (logoutButton && localStorage.getItem('meridian_session')) {
        logoutButton.classList.remove('hidden');
        logoutButton.addEventListener('click', () => {
          localStorage.removeItem('meridian_session');
          window.location.href = '/app/login';
        });
      }
    </script>
  </body>
</html>
