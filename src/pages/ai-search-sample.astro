---
import Layout from '../layouts/Layout.astro';

const schemaSnippet = `<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://example-saas.com/#organization",
      "name": "Example SaaS",
      "url": "https://example-saas.com"
    },
    {
      "@type": "Service",
      "@id": "https://example-saas.com/ai-governance-financial-services#service",
      "name": "AI governance software for financial services",
      "provider": { "@id": "https://example-saas.com/#organization" },
      "description": "A platform for AI model inventory, review workflow, policy evidence, and audit-ready governance."
    },
    {
      "@type": "FAQPage",
      "@id": "https://example-saas.com/ai-governance-financial-services#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What should banks check before buying AI governance software?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Banks should verify model inventory coverage, approval workflow, audit trail quality, policy mapping, exception handling, and integrations with existing risk systems."
          }
        }
      ]
    }
  ]
}
</script>`;

const pitchSnippet = `Subject: AI governance comparison resource for your next guide update

Hi,

I noticed your financial-services AI governance guide helps buyers compare
policy, review workflow, and audit evidence.

We put together a practical vendor comparison that covers implementation risk,
model inventory, approval paths, and evidence quality across the current
shortlist.

If you are updating the guide, I can send a concise vendor summary and source
notes for review.`;
---

<Layout
  title="Sample AI Search Report - Meridian"
  description="See the AI-search report Meridian generates: buyer prompts, missed answer surfaces, competitor pressure, generated page copy, FAQ, and paste-ready schema."
>
  <style>
    .sample-page {
      --ink: #e6edf3;
      --muted: #9aa7b2;
      --quiet: #6f7b86;
      --line: #30363d;
      --panel: rgba(13, 17, 23, 0.78);
      --panel-soft: rgba(143, 211, 255, 0.07);
      --green: #8be9a8;
      --blue: #8fd3ff;
      --amber: #ffcf91;
      --red: #ff9a9a;
      background:
        radial-gradient(circle at 78% 14%, rgba(143, 211, 255, 0.13), transparent 28%),
        linear-gradient(180deg, #080d13 0%, #0d1117 46%, #080d13 100%);
      color: var(--ink);
      font-family: Inter, sans-serif;
    }

    .sample-wrap {
      box-sizing: border-box;
      width: 100%;
      max-width: 1160px;
      margin: 0 auto;
      padding: 0 24px;
    }

    .sample-hero {
      min-height: calc(100vh - 64px);
      display: grid;
      align-items: end;
      border-bottom: 1px solid var(--line);
      background-image:
        linear-gradient(90deg, rgba(8, 13, 19, 0.99) 0%, rgba(8, 13, 19, 0.86) 48%, rgba(8, 13, 19, 0.18) 100%),
        url('/images/ai-search-hero.png');
      background-position: center;
      background-size: cover;
    }

    .sample-hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 0.95fr) minmax(360px, 0.75fr);
      gap: 28px;
      align-items: end;
      padding: 126px 0 56px;
    }

    .sample-kicker,
    .sample-label,
    .sample-chip {
      color: var(--green);
      font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size: 0.78rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    h1,
    h2,
    h3,
    h4 {
      margin: 0;
      font-family: "Plus Jakarta Sans", sans-serif;
      letter-spacing: 0;
    }

    h1 {
      max-width: 10.5ch;
      margin-top: 18px;
      font-size: clamp(3.25rem, 8vw, 7rem);
      line-height: 0.9;
    }

    .sample-hero-copy {
      max-width: 720px;
      margin: 24px 0 0;
      color: var(--muted);
      font-size: 1.1rem;
      line-height: 1.75;
    }

    .sample-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 30px;
    }

    .sample-primary,
    .sample-secondary {
      min-height: 46px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 8px;
      padding: 12px 16px;
      font-weight: 800;
      text-decoration: none;
    }

    .sample-primary {
      background: var(--green);
      color: #081019;
    }

    .sample-primary:hover {
      background: #b6f4c8;
    }

    .sample-secondary {
      border: 1px solid rgba(143, 211, 255, 0.42);
      background: rgba(8, 16, 25, 0.66);
      color: var(--ink);
    }

    .hero-proof,
    .sample-panel,
    .sample-card,
    .code-panel {
      border: 1px solid var(--line);
      border-radius: 8px;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.014));
    }

    .hero-proof {
      padding: 18px;
      backdrop-filter: blur(16px);
    }

    .proof-row {
      display: grid;
      grid-template-columns: 86px 1fr;
      gap: 14px;
      border-bottom: 1px solid rgba(48, 54, 61, 0.72);
      padding: 14px 0;
    }

    .proof-row:first-child {
      padding-top: 0;
    }

    .proof-row:last-child {
      border-bottom: 0;
      padding-bottom: 0;
    }

    .proof-row strong {
      color: var(--blue);
      font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size: 0.78rem;
      text-transform: uppercase;
    }

    .proof-row span,
    .sample-panel p,
    .sample-card p,
    .sample-card li,
    .asset-copy,
    .code-panel p {
      color: var(--muted);
      line-height: 1.65;
    }

    .sample-band {
      padding: 64px 0;
      border-bottom: 1px solid var(--line);
    }

    .section-head {
      display: grid;
      grid-template-columns: minmax(0, 0.92fr) minmax(280px, 0.55fr);
      gap: 24px;
      align-items: end;
      margin-bottom: 24px;
    }

    .section-head h2 {
      max-width: 740px;
      margin-top: 10px;
      font-size: clamp(2rem, 4.6vw, 4rem);
      line-height: 0.98;
    }

    .section-head p {
      color: var(--muted);
      line-height: 1.7;
    }

    .sample-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 16px;
    }

    .sample-grid.two {
      grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    }

    .sample-panel,
    .sample-card,
    .code-panel {
      padding: 22px;
    }

    .sample-card h3,
    .sample-panel h3 {
      color: var(--ink);
      font-size: 1.18rem;
    }

    .sample-panel.large h3 {
      font-size: clamp(1.7rem, 3vw, 2.65rem);
      line-height: 1.05;
    }

    .metric {
      display: grid;
      gap: 10px;
      min-height: 178px;
    }

    .metric strong {
      color: var(--blue);
      font-size: 2.2rem;
      line-height: 1;
    }

    .metric.bad strong {
      color: var(--red);
    }

    .metric.warn strong {
      color: var(--amber);
    }

    .metric span {
      color: var(--quiet);
      font-size: 0.9rem;
      line-height: 1.5;
    }

    .prompt-table {
      display: grid;
      gap: 10px;
      margin-top: 16px;
    }

    .prompt-row {
      display: grid;
      grid-template-columns: 112px 1fr 110px;
      gap: 12px;
      align-items: start;
      border: 1px solid rgba(48, 54, 61, 0.72);
      border-radius: 8px;
      background: rgba(8, 13, 19, 0.48);
      padding: 13px;
    }

    .prompt-row strong,
    .asset-table strong {
      color: var(--blue);
      font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size: 0.78rem;
      text-transform: uppercase;
    }

    .prompt-row p,
    .prompt-row span {
      margin: 0;
      color: var(--muted);
      line-height: 1.55;
    }

    .prompt-row .miss {
      color: var(--red);
      font-weight: 800;
    }

    .prompt-row .weak {
      color: var(--amber);
      font-weight: 800;
    }

    .asset-shell {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(300px, 0.58fr);
      gap: 16px;
      align-items: start;
    }

    .asset-copy h3 {
      margin-bottom: 10px;
      color: var(--ink);
      font-size: clamp(1.55rem, 3vw, 2.35rem);
      line-height: 1.1;
    }

    .asset-copy h4 {
      margin: 22px 0 8px;
      color: var(--ink);
      font-size: 1rem;
    }

    .asset-copy p {
      margin: 0;
      color: var(--muted);
      line-height: 1.72;
    }

    .asset-table {
      display: grid;
      gap: 10px;
      margin-top: 14px;
    }

    .asset-table div {
      display: grid;
      gap: 6px;
      border: 1px solid rgba(48, 54, 61, 0.72);
      border-radius: 8px;
      padding: 12px;
      background: rgba(8, 13, 19, 0.48);
    }

    .asset-table span {
      color: var(--muted);
      line-height: 1.55;
    }

    .code-panel {
      background: rgba(5, 8, 13, 0.76);
    }

    .code-panel h3 {
      color: var(--ink);
      font-size: 1.1rem;
    }

    pre {
      max-height: 520px;
      overflow: auto;
      margin: 16px 0 0;
      border-radius: 8px;
      background: #05080d;
      padding: 16px;
    }

    code {
      color: #c9d1d9;
      font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size: 0.78rem;
      line-height: 1.55;
      white-space: pre;
    }

    .deliverables {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 14px;
    }

    .deliverable {
      display: grid;
      gap: 10px;
      border: 1px solid rgba(48, 54, 61, 0.72);
      border-radius: 8px;
      padding: 16px;
      background: rgba(8, 13, 19, 0.48);
    }

    .deliverable strong {
      color: var(--green);
      font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size: 0.78rem;
      text-transform: uppercase;
    }

    .deliverable span {
      color: var(--muted);
      line-height: 1.55;
    }

    .sample-cta {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 22px;
      align-items: center;
      border: 1px solid rgba(139, 233, 168, 0.42);
      border-radius: 8px;
      background: linear-gradient(90deg, rgba(139, 233, 168, 0.13), rgba(143, 211, 255, 0.08));
      padding: 24px;
    }

    .sample-cta h2 {
      font-size: clamp(1.8rem, 3.6vw, 3rem);
      line-height: 1;
    }

    .sample-cta p {
      max-width: 720px;
      color: var(--muted);
      line-height: 1.7;
    }

    @media (max-width: 920px) {
      .sample-hero-grid,
      .section-head,
      .sample-grid,
      .sample-grid.two,
      .asset-shell,
      .deliverables,
      .sample-cta {
        grid-template-columns: 1fr;
      }

      .hero-proof {
        max-width: 620px;
      }
    }

    @media (max-width: 640px) {
      .sample-wrap {
        padding: 0 20px;
      }

      .sample-hero {
        min-height: auto;
      }

      .sample-hero-grid {
        padding: 110px 0 46px;
      }

      h1 {
        max-width: 8.8ch;
        font-size: clamp(2.55rem, 12vw, 3.25rem);
      }

      .sample-hero-copy,
      .sample-actions {
        max-width: 320px;
      }

      .sample-actions {
        display: grid;
      }

      .sample-actions a,
      .sample-cta a {
        width: 100%;
        box-sizing: border-box;
      }

      .proof-row,
      .prompt-row {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <div class="sample-page">
    <section class="sample-hero">
      <div class="sample-wrap">
        <div class="sample-hero-grid">
          <div>
            <div class="sample-kicker">Sample AI-search report</div>
            <h1>Your buyer asked AI. You were missing.</h1>
            <p class="sample-hero-copy">
              Most SEO reports tell you what already happened in Google. This shows the buyer questions where AI systems are forming the shortlist without you, then gives you the page copy and schema to fight back.
            </p>
            <div class="sample-actions">
              <a class="sample-primary" href="/ai-search#plans">Start a $99 monitor</a>
              <a class="sample-secondary" href="#generated-assets">See generated assets</a>
            </div>
          </div>

          <aside class="hero-proof" aria-label="Sample report summary">
            <div class="proof-row">
              <strong>Company</strong>
              <span>Fictional B2B SaaS selling AI governance software to financial services teams.</span>
            </div>
            <div class="proof-row">
              <strong>Finding</strong>
              <span>Buyers ask five high-intent AI prompts. The company is missing from four and weak in one.</span>
            </div>
            <div class="proof-row">
              <strong>Output</strong>
              <span>Priority prompts, competitor answer map, comparison-page draft, FAQ, JSON-LD, and outreach pitch.</span>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="sample-band">
      <div class="sample-wrap">
        <div class="section-head">
          <div>
            <div class="sample-label">The uncomfortable part</div>
            <h2>Your buyer asked AI. You did not make the shortlist.</h2>
          </div>
          <p>
            This is the moment the product has to sell: a prospect can be researching your category without ever touching a search result, ad, or sales form. Meridian shows where that happens and what evidence the model is using instead.
          </p>
        </div>

        <div class="sample-grid">
          <article class="sample-card metric bad">
            <span class="sample-chip">Visibility</span>
            <strong>24/100</strong>
            <p>You are not named in shortlist answers for the most commercial prompt cluster.</p>
          </article>
          <article class="sample-card metric warn">
            <span class="sample-chip">Citation strength</span>
            <strong>38/100</strong>
            <p>Your site has decent product language, but few pages that answer buyer-risk questions directly.</p>
          </article>
          <article class="sample-card metric">
            <span class="sample-chip">Competitor pressure</span>
            <strong>78/100</strong>
            <p>Competitors appear through comparison pages, partner directories, and implementation guides.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="sample-band">
      <div class="sample-wrap sample-grid two">
        <article class="sample-panel large">
          <div class="sample-label">Prompt map</div>
          <h3>The report starts where revenue starts: buyer questions.</h3>
          <p>
            Meridian does not ask whether you rank for a keyword. It asks whether an AI answer can confidently name you when a buyer describes the problem, the industry, the risk, and the alternatives.
          </p>
        </article>

        <div class="sample-panel">
          <h3>Sample prompt results</h3>
          <div class="prompt-table">
            <div class="prompt-row">
              <strong>Shortlist</strong>
              <p>Which AI governance platforms should a financial-services team compare?</p>
              <span class="miss">Omitted</span>
            </div>
            <div class="prompt-row">
              <strong>Risk</strong>
              <p>What should banks check before buying AI governance software?</p>
              <span class="weak">Weak mention</span>
            </div>
            <div class="prompt-row">
              <strong>Compare</strong>
              <p>How does this vendor compare with Credo AI, Holistic AI, and Fairly AI?</p>
              <span class="miss">Omitted</span>
            </div>
            <div class="prompt-row">
              <strong>Deploy</strong>
              <p>Which tools are strongest for model inventory and approval workflow?</p>
              <span class="miss">Omitted</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="sample-band" id="generated-assets">
      <div class="sample-wrap">
        <div class="section-head">
          <div>
            <div class="sample-label">What you get back</div>
            <h2>Not "write a comparison page." The page draft, FAQ, and code blocks.</h2>
          </div>
          <p>
            The paid product now generates implementation-ready assets from the diagnosis. You can hand this to a marketer, developer, or founder and have the first corrective asset live the same day.
          </p>
        </div>

        <div class="asset-shell">
          <article class="sample-panel asset-copy">
            <div class="sample-chip">Generated page draft</div>
            <h3>AI governance software for financial services: what buyers should verify before choosing</h3>
            <p>
              A financial-services buyer is not shopping for "AI governance" in the abstract. They are trying to avoid regulatory exposure, model inventory sprawl, unclear approval paths, and a tool that looks useful in a demo but cannot survive review by risk, legal, compliance, and data science.
            </p>
            <h4>Where the shortlist usually goes wrong</h4>
            <p>
              Most vendor pages describe control, transparency, and workflow. Those claims are too soft for a buyer comparing platforms. The useful comparison names the operating questions: who owns the model register, how exceptions are approved, how evidence is stored, and what happens when a policy changes.
            </p>
            <h4>Proof to ask every vendor for</h4>
            <div class="asset-table">
              <div>
                <strong>Implementation</strong>
                <span>Ask for the first 30-day rollout plan, including required data sources, owners, and review gates.</span>
              </div>
              <div>
                <strong>Audit trail</strong>
                <span>Ask to see how a model decision, exception, approval, and policy change are represented in the product.</span>
              </div>
              <div>
                <strong>Comparison</strong>
                <span>Compare against Credo AI, Holistic AI, Fairly AI, and internal workflow tools instead of pretending the category is empty.</span>
              </div>
            </div>
          </article>

          <aside class="sample-panel">
            <h3>Why this matters</h3>
            <p>
              AI answers need language they can synthesize. If your site does not name the category, alternatives, risks, and proof points, the answer engine will borrow that structure from someone else.
            </p>
            <div class="asset-table">
              <div>
                <strong>Before</strong>
                <span>"Publish content about implementation risk."</span>
              </div>
              <div>
                <strong>After</strong>
                <span>A ready-to-edit comparison page, FAQ, JSON-LD schema, and a citation pitch.</span>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="sample-band">
      <div class="sample-wrap asset-shell">
        <article class="code-panel">
          <h3>Paste-ready structured data</h3>
          <p>Meridian generates schema that reinforces the entity, service, FAQ, and breadcrumb context for the page.</p>
          <pre><code>{schemaSnippet}</code></pre>
        </article>

        <article class="code-panel">
          <h3>Generated citation pitch</h3>
          <p>A report also gives you the external-source motion, because your own site is necessary but rarely enough.</p>
          <pre><code>{pitchSnippet}</code></pre>
        </article>
      </div>
    </section>

    <section class="sample-band">
      <div class="sample-wrap">
        <div class="section-head">
          <div>
            <div class="sample-label">Why people keep paying</div>
            <h2>The first report fixes one hole. The monitor catches drift.</h2>
          </div>
          <p>
            AI answers change as competitors publish, directories update, and buyer language shifts. The monthly product is a lightweight operating loop, not a one-time PDF.
          </p>
        </div>

        <div class="deliverables">
          <div class="deliverable">
            <strong>Prompt watchlist</strong>
            <span>Commercial buyer questions tracked by intent: shortlist, compare, risk, implementation, procurement.</span>
          </div>
          <div class="deliverable">
            <strong>Answer evidence</strong>
            <span>Who appears, which sources influence the answer, and where your site is too thin to cite.</span>
          </div>
          <div class="deliverable">
            <strong>Generated fixes</strong>
            <span>Page copy, FAQ, schema, snippets, and external-source pitch drafts.</span>
          </div>
          <div class="deliverable">
            <strong>Next action</strong>
            <span>A ranked queue so you know what to ship before the next monitoring cycle.</span>
          </div>
        </div>
      </div>
    </section>

    <section class="sample-band">
      <div class="sample-wrap">
        <div class="sample-cta">
          <div>
            <h2>Find the buyer questions where AI is already choosing for you.</h2>
            <p>
              Start with the $99 monitor. You get the scorecard, prompt map, competitor pressure, and generated implementation assets without waiting for a consulting kickoff.
            </p>
          </div>
          <a class="sample-primary" href="/ai-search#plans">Start monitor</a>
        </div>
      </div>
    </section>
  </div>
</Layout>
