---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Meridian" description="Tell us about your business and what you're trying to grow. We'll take a look and come back with honest observations.">

  <!-- Hero -->
  <section class="bg-gradient-to-b from-dark to-dark-card pt-32 pb-20 md:pb-28">
    <div class="mx-auto max-w-7xl px-6">
      <h1 class="text-5xl md:text-7xl font-extrabold text-hero-text leading-[1.05] tracking-tight max-w-3xl">
        Let's look at your site.
      </h1>
      <p class="mt-6 text-lg text-body-muted max-w-2xl leading-relaxed">
        Tell us a bit about where you are and what you're trying to grow. We'll take a look and come back with honest observations — no pitch deck.
      </p>
    </div>
  </section>

  <!-- Form -->
  <section class="bg-white py-24 md:py-32">
    <div class="mx-auto max-w-2xl px-6">
      <form action="#" method="POST" class="space-y-6">
        <div>
          <label for="name" class="block text-sm font-medium text-dark mb-2">Name <span class="text-accent">*</span></label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-dark placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-colors"
            placeholder="Your name"
          />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-dark mb-2">Email <span class="text-accent">*</span></label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-dark placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-colors"
            placeholder="you@company.com"
          />
        </div>
        <div>
          <label for="website" class="block text-sm font-medium text-dark mb-2">Website URL <span class="text-accent">*</span></label>
          <input
            type="url"
            id="website"
            name="website"
            required
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-dark placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-colors"
            placeholder="https://yoursite.com"
          />
        </div>
        <div>
          <label for="goals" class="block text-sm font-medium text-dark mb-2">What are you trying to grow?</label>
          <textarea
            id="goals"
            name="goals"
            rows="4"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-dark placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-colors resize-y"
            placeholder="Tell us about your goals..."
          ></textarea>
        </div>
        <div>
          <label for="referral" class="block text-sm font-medium text-dark mb-2">How did you hear about us? <span class="text-light-text font-normal">(optional)</span></label>
          <input
            type="text"
            id="referral"
            name="referral"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 text-dark placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-colors"
            placeholder="Google, referral, Twitter..."
          />
        </div>
        <button
          type="submit"
          class="w-full md:w-auto inline-flex items-center justify-center px-8 py-3.5 bg-accent hover:bg-accent-hover text-white font-medium rounded-lg transition-colors"
        >
          Send it &rarr;
        </button>
      </form>
      <p class="mt-8 text-sm text-light-text">We respond within 1 business day. If you'd prefer to talk directly: hello@bymeridian.com</p>
    </div>
  </section>

</Layout>
