---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Meet Your AI SEO Team — Meridian" 
  description="Six specialized AI agents working together as your autonomous SEO department. Daily audits, content creation, link building, and trend monitoring — all for a fraction of hiring a team."
>

  <!-- Hero -->
  <section class="relative min-h-[80vh] flex items-center bg-gradient-to-b from-dark to-dark-card">
    <div class="mx-auto max-w-7xl px-6 pt-24 pb-20">
      <div class="max-w-4xl">
        <p class="text-xs font-medium uppercase tracking-[0.2em] text-accent mb-6">The Meridian AI Fleet</p>
        <h1 class="text-5xl md:text-7xl font-extrabold text-hero-text leading-[1.05] tracking-tight">
          Meet your AI<br/>SEO team.
        </h1>
        <p class="mt-6 text-lg text-body-muted max-w-2xl leading-relaxed">
          Six specialist agents. One coordinated system. They audit your site every morning, research keywords, write content, find link opportunities, and monitor industry trends — then synthesize everything into clear, actionable recommendations.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a href="/pricing" class="inline-flex items-center px-6 py-3 bg-accent hover:bg-accent-hover text-white text-sm font-medium rounded-lg transition-colors">
            Start with your team &rarr;
          </a>
          <a href="#how-it-works" class="inline-flex items-center px-6 py-3 border border-dark-border text-body-muted hover:text-white hover:border-white/20 text-sm font-medium rounded-lg transition-colors">
            See how they work together
          </a>
        </div>
      </div>
    </div>
    
    <!-- Animated agent nodes decoration -->
    <div class="absolute right-0 top-1/2 -translate-y-1/2 w-1/2 h-full opacity-20 hidden lg:block pointer-events-none">
      <svg class="w-full h-full" viewBox="0 0 400 400" fill="none">
        <!-- Central coordinator -->
        <circle cx="200" cy="200" r="40" fill="url(#coordinatorGradient)" opacity="0.8">
          <animate attributeName="r" values="40;45;40" dur="3s" repeatCount="indefinite"/>
        </circle>
        <!-- Orbiting agents -->
        <circle cx="200" cy="80" r="20" fill="#6366F1" opacity="0.6">
          <animate attributeName="cy" values="80;85;80" dur="2.5s" repeatCount="indefinite"/>
        </circle>
        <circle cx="320" cy="140" r="20" fill="#8B5CF6" opacity="0.6">
          <animate attributeName="cx" values="320;325;320" dur="3s" repeatCount="indefinite"/>
        </circle>
        <circle cx="320" cy="260" r="20" fill="#EC4899" opacity="0.6">
          <animate attributeName="cy" values="260;255;260" dur="2.8s" repeatCount="indefinite"/>
        </circle>
        <circle cx="200" cy="320" r="20" fill="#F59E0B" opacity="0.6">
          <animate attributeName="cy" values="320;325;320" dur="2.2s" repeatCount="indefinite"/>
        </circle>
        <circle cx="80" cy="260" r="20" fill="#10B981" opacity="0.6">
          <animate attributeName="cx" values="80;75;80" dur="2.7s" repeatCount="indefinite"/>
        </circle>
        <circle cx="80" cy="140" r="20" fill="#3B82F6" opacity="0.6">
          <animate attributeName="cx" values="80;85;80" dur="3.2s" repeatCount="indefinite"/>
        </circle>
        <!-- Connection lines -->
        <line x1="200" y1="200" x2="200" y2="80" stroke="#6366F1" stroke-width="1" opacity="0.3"/>
        <line x1="200" y1="200" x2="320" y2="140" stroke="#8B5CF6" stroke-width="1" opacity="0.3"/>
        <line x1="200" y1="200" x2="320" y2="260" stroke="#EC4899" stroke-width="1" opacity="0.3"/>
        <line x1="200" y1="200" x2="200" y2="320" stroke="#F59E0B" stroke-width="1" opacity="0.3"/>
        <line x1="200" y1="200" x2="80" y2="260" stroke="#10B981" stroke-width="1" opacity="0.3"/>
        <line x1="200" y1="200" x2="80" y2="140" stroke="#3B82F6" stroke-width="1" opacity="0.3"/>
        <defs>
          <radialGradient id="coordinatorGradient" cx="50%" cy="50%">
            <stop offset="0%" stop-color="#E8714A"/>
            <stop offset="100%" stop-color="#CF5A35"/>
          </radialGradient>
        </defs>
      </svg>
    </div>
  </section>

  <!-- The 6 Agents Grid -->
  <section class="bg-white py-24 md:py-32">
    <div class="mx-auto max-w-7xl px-6">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl md:text-[44px] font-semibold text-dark leading-tight">Six specialists. One mission.</h2>
        <p class="mt-4 text-light-text text-lg">Each agent has a focused role, specialized tools, and a defined output. They don't just chat — they deliver work product.</p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Tech Auditor -->
        <div class="group relative bg-gradient-to-br from-slate-50 to-white border border-slate-200 rounded-2xl p-8 hover:shadow-xl hover:shadow-indigo-100/50 transition-all duration-300 hover:-translate-y-1">
          <div class="absolute top-0 right-0 w-24 h-24 bg-blue-500/5 rounded-bl-full"></div>
          <div class="relative">
            <div class="w-14 h-14 flex items-center justify-center rounded-xl bg-blue-500/10 mb-5">
              <svg class="w-7 h-7 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-dark mb-2">Tech Auditor</h3>
            <p class="text-sm text-accent font-medium mb-3">Daily Technical SEO Audits</p>
            <p class="text-light-text leading-relaxed text-[15px]">
              Crawls your site every morning checking Core Web Vitals, broken links, indexation issues, schema markup, and CTR opportunities. Creates a prioritized fix list with copy-paste code blocks.
            </p>
            <div class="mt-4 flex flex-wrap gap-2">
              <span class="text-xs px-2 py-1 bg-slate-100 text-slate-600 rounded-full">Crawl Analysis</span>
              <span class="text-xs px-2 py-1 bg-slate-100 text-slate-600 rounded-full">Schema Validation</span>
              <span class="text-xs px-2 py-1 bg-slate-100 text-slate-600 rounded-full">CWV Monitoring</span>
            </div>
          </div>
        </div>

        <!-- Content Strategist -->
        <div class="group relative bg-gradient-to-br from-slate-50 to-white border border-slate-200 rounded-2xl p-8 hover:shadow-xl hover:shadow-indigo-100/50 transition-all duration-300 hover:-translate-y-1">
          <div class="absolute top-0 right-0 w-24 h-24 bg-purple-500/5 rounded-bl-full"></div>
          <div class="relative">
            <div class="w-14 h-14 flex items-center justify-center rounded-xl bg-purple-500/10 mb-5">
              <svg class="w-7 h-7 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-dark mb-2">Content Strategist</h3>
            <p class="text-sm text-purple-600 font-medium mb-3">Keyword Research & Content Briefs</p>
            <p class="text-light-text leading-relaxed text-[15px]">
              Analyzes competitor gaps, identifies trending topics in your industry, and creates detailed content briefs with priority scores. Knows what to write before writing begins.
            </p>
            <div class="mt-4 flex flex-wrap gap-2">
              <span class="text-xs px-2 py-1 bg-slate-100 text-slate-600 rounded-full">Gap Analysis</span>
              <span class="text-xs px-2 py-1 bg-slate-100 text-slate-600 rounded-full">Trend Detection</span>
              <span class="text-xs px-2 py-1 bg-slate-100 text-slate-600 rounded-full">Brief Creation</span>
            </div>
          </div>
        </div>

        <!-- Content Creator -->
        <div class="group relative bg-gradient-to-br from-slate-50 to-white border border-slate-200 rounded-2xl p-8 hover:shadow-xl hover:shadow-indigo-100/50 transition-all duration-300 hover:-translate-y-1">
          <div class="absolute top-0 right-0 w-24 h-24 bg-pink-500/5 rounded-bl-full"></div>
          <div class="relative">
            <div class="w-14 h-14 flex items-center justify-center rounded-xl bg-pink-500/10 mb-5">
              <svg class="w-7 h-7 text-pink-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-dark mb-2">Content Creator</h3>
            <p class="text-sm text-pink-600 font-medium mb-3">SEO-Optimized Content Writing</p>
            <p class="text-light-text leading-relaxed text-[15px]">
              Writes complete drafts based on approved briefs, matching your brand voice. Uses your knowledge base for accuracy. Produces ready-to-publish markdown with meta descriptions.
            </p>
            <div class="mt-4 flex flex-wrap gap-2">
              <span class="text-xs px-2 py-1 bg-slate-100 text-slate-600 rounded-full">Brand Voice Match</span>
              <span class="text-xs px-2 py-1 bg-slate-100 text-slate-600 rounded-full">SEO Optimization</span>
              <span class="text-xs px-2 py-1 bg-slate-100 text-slate-600 rounded-full">Knowledge Base</span>
            </div>
          </div>
        </div>

        <!-- Link Builder -->
        <div class="group relative bg-gradient-to-br from-slate-50 to-white border border-slate-200 rounded-2xl p-8 hover:shadow-xl hover:shadow-indigo-100/50 transition-all duration-300 hover:-translate-y-1">
          <div class="absolute top-0 right-0 w-24 h-24 bg-emerald-500/5 rounded-bl-full"></div>
          <div class="relative">
            <div class="w-14 h-14 flex items-center justify-center rounded-xl bg-emerald-500/10 mb-5">
              <svg class="w-7 h-7 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-dark mb-2">Link Builder</h3>
            <p class="text-sm text-emerald-600 font-medium mb-3">Link Prospecting & Outreach</p>
            <p class="text-light-text leading-relaxed text-[15px]">
              Finds high-quality link opportunities, scores prospects by relevance and authority, and generates personalized outreach emails. Tracks the entire pipeline from prospect to placement.
            </p>
            <div class="mt-4 flex flex-wrap gap-2">
              <span class="text-xs px-2 py-1 bg-slate-100 text-slate-600 rounded-full">Prospect Scoring</span>
              <span class="text-xs px-2 py-1 bg-slate-100 text-slate-600 rounded-full">Outreach Emails</span>
              <span class="text-xs px-2 py-1 bg-slate-100 text-slate-600 rounded-full">Pipeline Tracking</span>
            </div>
          </div>
        </div>

        <!-- Trend Scout -->
        <div class="group relative bg-gradient-to-br from-slate-50 to-white border border-slate-200 rounded-2xl p-8 hover:shadow-xl hover:shadow-indigo-100/50 transition-all duration-300 hover:-translate-y-1">
          <div class="absolute top-0 right-0 w-24 h-24 bg-amber-500/5 rounded-bl-full"></div>
          <div class="relative">
            <div class="w-14 h-14 flex items-center justify-center rounded-xl bg-amber-500/10 mb-5">
              <svg class="w-7 h-7 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-dark mb-2">Trend Scout</h3>
            <p class="text-sm text-amber-600 font-medium mb-3">Industry News & Algorithm Monitoring</p>
            <p class="text-light-text leading-relaxed text-[15px]">
              Monitors industry publications, social signals, and algorithm updates daily. Alerts you to emerging trends and recommends actions before your competitors react.
            </p>
            <div class="mt-4 flex flex-wrap gap-2">
              <span class="text-xs px-2 py-1 bg-slate-100 text-slate-600 rounded-full">News Monitoring</span>
              <span class="text-xs px-2 py-1 bg-slate-100 text-slate-600 rounded-full">Algorithm Alerts</span>
              <span class="text-xs px-2 py-1 bg-slate-100 text-slate-600 rounded-full">Competitor Intel</span>
            </div>
          </div>
        </div>

        <!-- Coordinator -->
        <div class="group relative bg-gradient-to-br from-orange-50 to-white border-2 border-accent/20 rounded-2xl p-8 hover:shadow-xl hover:shadow-orange-100/50 transition-all duration-300 hover:-translate-y-1">
          <div class="absolute top-0 right-0 w-24 h-24 bg-accent/5 rounded-bl-full"></div>
          <div class="relative">
            <div class="w-14 h-14 flex items-center justify-center rounded-xl bg-accent/10 mb-5">
              <svg class="w-7 h-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-dark mb-2">Coordinator</h3>
            <p class="text-sm text-accent font-medium mb-3">User-Facing Orchestrator</p>
            <p class="text-light-text leading-relaxed text-[15px]">
              Your single point of contact. Synthesizes all agent outputs, runs daily standups, prioritizes your work queue, and handles your questions. The only agent you need to talk to.
            </p>
            <div class="mt-4 flex flex-wrap gap-2">
              <span class="text-xs px-2 py-1 bg-accent/10 text-accent rounded-full">Your Contact</span>
              <span class="text-xs px-2 py-1 bg-slate-100 text-slate-600 rounded-full">Priority Queue</span>
              <span class="text-xs px-2 py-1 bg-slate-100 text-slate-600 rounded-full">Daily Standups</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works / Agent Handoff Diagram -->
  <section id="how-it-works" class="bg-hero-text py-24 md:py-32">
    <div class="mx-auto max-w-7xl px-6">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl md:text-[44px] font-semibold text-dark leading-tight">How the agents work together</h2>
        <p class="mt-4 text-light-text text-lg">A coordinated workflow where specialists hand off to each other, and the Coordinator keeps you informed every step of the way.</p>
      </div>

      <!-- Visual Workflow Diagram -->
      <div class="bg-white rounded-3xl p-8 md:p-12 shadow-xl border border-slate-200">
        <div class="relative">
          <!-- Workflow SVG Diagram -->
          <div class="hidden md:block">
            <svg class="w-full" viewBox="0 0 900 400" fill="none">
              <!-- Row 1: Tech Auditor (Foundation) -->
              <rect x="50" y="50" width="160" height="80" rx="12" fill="#DBEAFE" stroke="#3B82F6" stroke-width="2"/>
              <text x="130" y="85" text-anchor="middle" font-size="14" font-weight="600" fill="#1E40AF">Tech Auditor</text>
              <text x="130" y="105" text-anchor="middle" font-size="11" fill="#3B82F6">Daily Site Crawl</text>
              <text x="130" y="120" text-anchor="middle" font-size="11" fill="#3B82F6">& Issue Detection</text>

              <!-- Row 1: Trend Scout (Parallel) -->
              <rect x="370" y="50" width="160" height="80" rx="12" fill="#FEF3C7" stroke="#F59E0B" stroke-width="2"/>
              <text x="450" y="85" text-anchor="middle" font-size="14" font-weight="600" fill="#92400E">Trend Scout</text>
              <text x="450" y="105" text-anchor="middle" font-size="11" fill="#F59E0B">Industry Monitoring</text>
              <text x="450" y="120" text-anchor="middle" font-size="11" fill="#F59E0B">& Algorithm Alerts</text>

              <!-- Row 1: Link Builder (Parallel) -->
              <rect x="690" y="50" width="160" height="80" rx="12" fill="#D1FAE5" stroke="#10B981" stroke-width="2"/>
              <text x="770" y="85" text-anchor="middle" font-size="14" font-weight="600" fill="#065F46">Link Builder</text>
              <text x="770" y="105" text-anchor="middle" font-size="11" fill="#10B981">Prospect Discovery</text>
              <text x="770" y="120" text-anchor="middle" font-size="11" fill="#10B981">& Scoring</text>

              <!-- Connection arrows to Row 2 -->
              <path d="M210 90 L290 90" stroke="#94A3B8" stroke-width="2" marker-end="url(#arrowhead)"/>
              <path d="M450 130 L450 170" stroke="#94A3B8" stroke-width="2" marker-end="url(#arrowhead)"/>
              <path d="M690 90 L610 90" stroke="#94A3B8" stroke-width="2" marker-end="url(#arrowhead)"/>

              <!-- Row 2: Content Strategist -->
              <rect x="210" y="170" width="180" height="80" rx="12" fill="#F3E8FF" stroke="#8B5CF6" stroke-width="2"/>
              <text x="300" y="205" text-anchor="middle" font-size="14" font-weight="600" fill="#6B21A8">Content Strategist</text>
              <text x="300" y="225" text-anchor="middle" font-size="11" fill="#8B5CF6">Keyword Research</text>
              <text x="300" y="240" text-anchor="middle" font-size="11" fill="#8B5CF6">& Brief Creation</text>

              <!-- Row 2: Coordinator (Receives from all) -->
              <rect x="530" y="170" width="160" height="80" rx="12" fill="#FFF7ED" stroke="#E8714A" stroke-width="3"/>
              <text x="610" y="205" text-anchor="middle" font-size="14" font-weight="700" fill="#9A3412">Coordinator</text>
              <text x="610" y="225" text-anchor="middle" font-size="11" fill="#E8714A">Synthesis & Updates</text>
              <text x="610" y="240" text-anchor="middle" font-size="11" fill="#E8714A">User Communication</text>

              <!-- Connections -->
              <path d="M390 210 L530 210" stroke="#94A3B8" stroke-width="2" marker-end="url(#arrowhead)"/>
              <path d="M770 90 L770 150 L690 190" stroke="#94A3B8" stroke-width="2" fill="none" marker-end="url(#arrowhead)"/>

              <!-- Row 3: Content Creator (Triggered by brief) -->
              <rect x="210" y="290" width="180" height="80" rx="12" fill="#FCE7F3" stroke="#EC4899" stroke-width="2"/>
              <text x="300" y="325" text-anchor="middle" font-size="14" font-weight="600" fill="#9D174D">Content Creator</text>
              <text x="300" y="345" text-anchor="middle" font-size="11" fill="#EC4899">Draft Writing</text>
              <text x="300" y="360" text-anchor="middle" font-size="11" fill="#EC4899">& Optimization</text>

              <!-- Connection: Strategist to Creator -->
              <path d="M300 250 L300 290" stroke="#94A3B8" stroke-width="2" marker-end="url(#arrowhead)"/>

              <!-- Connection: Creator back to Coordinator -->
              <path d="M390 330 L530 250" stroke="#94A3B8" stroke-width="2" marker-end="url(#arrowhead)"/>

              <!-- Labels -->
              <text x="250" y="85" font-size="10" fill="#64748B">Data</text>
              <text x="650" y="85" font-size="10" fill="#64748B">Opportunities</text>
              <text x="460" y="155" font-size="10" fill="#64748B">Signals</text>
              <text x="460" y="220" font-size="10" fill="#64748B">Briefs</text>
              <text x="310" y="275" font-size="10" fill="#64748B">Brief Approved</text>
              <text x="420" y="310" font-size="10" fill="#64748B">Draft Ready</text>

              <!-- Arrow marker definition -->
              <defs>
                <marker id="arrowhead" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
                  <polygon points="0 0, 10 3.5, 0 7" fill="#94A3B8"/>
                </marker>
              </defs>
            </svg>
          </div>

          <!-- Mobile-friendly text version -->
          <div class="md:hidden space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center shrink-0">
                <span class="text-blue-600 font-bold">1</span>
              </div>
              <div>
                <p class="font-semibold text-dark">Tech Auditor crawls your site</p>
                <p class="text-light-text text-sm">Detects technical issues, schema problems, and performance gaps daily.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-amber-100 flex items-center justify-center shrink-0">
                <span class="text-amber-600 font-bold">2</span>
              </div>
              <div>
                <p class="font-semibold text-dark">Trend Scout monitors industry</p>
                <p class="text-light-text text-sm">Tracks news, algorithm updates, and competitor moves in parallel.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-emerald-100 flex items-center justify-center shrink-0">
                <span class="text-emerald-600 font-bold">3</span>
              </div>
              <div>
                <p class="font-semibold text-dark">Link Builder finds opportunities</p>
                <p class="text-light-text text-sm">Discovers and scores link prospects with personalized outreach.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-purple-100 flex items-center justify-center shrink-0">
                <span class="text-purple-600 font-bold">4</span>
              </div>
              <div>
                <p class="font-semibold text-dark">Content Strategist creates briefs</p>
                <p class="text-light-text text-sm">Uses audit data and trends to build prioritized content briefs.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-pink-100 flex items-center justify-center shrink-0">
                <span class="text-pink-600 font-bold">5</span>
              </div>
              <div>
                <p class="font-semibold text-dark">Content Creator writes drafts</p>
                <p class="text-light-text text-sm">Produces SEO-optimized content matching your brand voice.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center shrink-0">
                <span class="text-accent font-bold">6</span>
              </div>
              <div>
                <p class="font-semibold text-dark">Coordinator synthesizes everything</p>
                <p class="text-light-text text-sm">Delivers unified reports, prioritizes actions, and communicates with you.</p>
              </div>
            </div>
