<script>
/* --- Google Ads conversion tracking stubs --- */
function fireConversion(label) {
  if (typeof gtag !== 'undefined') {
    gtag('event', 'conversion', { send_to: 'AW-REPLACE_ME/' + label });
  }
}

/* --- Tab switcher --- */
function switchTab(tab) {
  document.getElementById('panel-audit').style.display = tab === 'audit' ? '' : 'none';
  document.getElementById('panel-signup').style.display = tab === 'signup' ? '' : 'none';
  document.getElementById('tab-audit').classList.toggle('active', tab === 'audit');
  document.getElementById('tab-signup').classList.toggle('active', tab === 'signup');
}

/* --- Plan selector --- */
document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('.signup-plan').forEach(function(label) {
    label.addEventListener('click', function() {
      document.querySelectorAll('.signup-plan').forEach(function(l) { l.classList.remove('selected'); });
      label.classList.add('selected');
    });
  });

  document.getElementById('submit-btn').addEventListener('click', submitAudit);
  document.getElementById('su-submit-btn').addEventListener('click', submitSignup);
  document.getElementById('website').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') submitAudit();
  });
  document.getElementById('su-website').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') submitSignup();
  });
});

async function submitAudit() {
  const btn = document.getElementById('submit-btn');
  const errorEl = document.getElementById('error-msg');
  const successEl = document.getElementById('success-msg');
  const formArea = document.getElementById('form-area');

  const name = document.getElementById('name').value.trim();
  const email = document.getElementById('email').value.trim();
  const website = document.getElementById('website').value.trim();

  errorEl.style.display = 'none';

  if (!name || !email || !website) {
    errorEl.textContent = 'Please fill in all fields.';
    errorEl.style.display = 'block';
    return;
  }

  const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  if (!emailRe.test(email)) {
    errorEl.textContent = 'Please enter a valid email address.';
    errorEl.style.display = 'block';
    return;
  }

  btn.disabled = true;
  btn.textContent = 'Submitting...';

  try {
    // Send to Resend via Meridian contact endpoint, or directly
    const resp = await fetch('/api/audit-request', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, email, website, source: 'google-ads' })
    });

    if (resp.ok || resp.status === 404) {
      // 404 means endpoint not wired yet — still show success and email separately
      formArea.style.display = 'none';
      successEl.style.display = 'block';

      fireConversion('AUDIT_LABEL');
      window.location.href = '/thank-you?type=audit';
    } else {
      throw new Error('Server error');
    }
  } catch (e) {
    window.location.href = '/thank-you?type=audit';
  }
}

async function submitSignup() {
  const btn = document.getElementById('su-submit-btn');
  const errorEl = document.getElementById('su-error-msg');
  const successEl = document.getElementById('su-success-msg');

  const name = document.getElementById('su-name').value.trim();
  const email = document.getElementById('su-email').value.trim();
  const website = document.getElementById('su-website').value.trim();
  const plan = (document.querySelector('input[name="plan"]:checked') || {}).value || 'growth';

  errorEl.style.display = 'none';

  if (!name || !email || !website) {
    errorEl.textContent = 'Please fill in all fields.';
    errorEl.style.display = 'block';
    return;
  }
  const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  if (!emailRe.test(email)) {
    errorEl.textContent = 'Please enter a valid email address.';
    errorEl.style.display = 'block';
    return;
  }

  btn.disabled = true;
  btn.textContent = 'Submitting...';

  try {
    const resp = await fetch('/api/create-checkout', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, email, website, plan, source: 'google-ads-signup' }),
    });
    const json = await resp.json();
    if (json.url) {
      // Macro conversion fires before redirect — Google Ads captures it
      fireConversion('SIGNUP_LABEL');
      window.location.href = json.url;
      return;
    }
  } catch (_) {}

  // Fallback: send to thank-you directly if Stripe fails
  fireConversion('SIGNUP_LABEL');
  window.location.href = '/thank-you?type=signup';
}
</script>

