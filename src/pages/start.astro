---
// /start — Paid traffic landing page
// Optimized for Google Ads conversion: clear benefit, social proof, low-friction CTA
const title = "Get a Free SEO Audit — Meridian";
const description = "See exactly what's hurting your rankings and traffic. Free site audit, delivered in 24 hours. No commitment.";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="noindex" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Inter', sans-serif;
      background: #fff;
      color: #1a1a2e;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    /* NAV */
    nav {
      padding: 20px 24px;
      max-width: 1100px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .logo {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 800;
      font-size: 1.3rem;
      color: #1a1a2e;
      text-decoration: none;
      letter-spacing: -0.03em;
    }
    .logo span { color: #e8714a; }
    .nav-trust {
      font-size: 0.82rem;
      color: #888;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .nav-trust::before {
      content: "🔒";
      font-size: 0.75rem;
    }

    /* HERO */
    .hero {
      max-width: 760px;
      margin: 0 auto;
      padding: 60px 24px 40px;
      text-align: center;
    }
    .badge {
      display: inline-block;
      background: #fff4ef;
      color: #e8714a;
      font-size: 0.78rem;
      font-weight: 600;
      padding: 5px 12px;
      border-radius: 100px;
      margin-bottom: 20px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    h1 {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 800;
      line-height: 1.15;
      letter-spacing: -0.03em;
      color: #0f0f1a;
      margin-bottom: 20px;
    }
    h1 em {
      font-style: normal;
      color: #e8714a;
    }
    .hero-sub {
      font-size: 1.1rem;
      color: #555;
      max-width: 560px;
      margin: 0 auto 36px;
      line-height: 1.7;
    }

    /* FORM */
    .form-card {
      background: #f8f9fc;
      border: 1px solid #e8eaf0;
      border-radius: 16px;
      padding: 36px;
      max-width: 520px;
      margin: 0 auto 16px;
      text-align: left;
    }
    .form-label {
      font-size: 0.82rem;
      font-weight: 600;
      color: #444;
      display: block;
      margin-bottom: 6px;
    }
    .form-row {
      margin-bottom: 16px;
    }
    input[type="text"],
    input[type="email"],
    input[type="url"] {
      width: 100%;
      padding: 12px 14px;
      border: 1.5px solid #dde0ea;
      border-radius: 8px;
      font-size: 0.95rem;
      font-family: 'Inter', sans-serif;
      color: #1a1a2e;
      background: #fff;
      outline: none;
      transition: border-color 0.2s;
    }
    input:focus { border-color: #e8714a; }
    input::placeholder { color: #aaa; }
    .btn-cta {
      display: block;
      width: 100%;
      padding: 16px;
      background: #e8714a;
      color: #fff;
      border: none;
      border-radius: 10px;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 700;
      font-size: 1.05rem;
      cursor: pointer;
      transition: background 0.2s, transform 0.1s;
      margin-top: 8px;
      text-align: center;
    }
    .btn-cta:hover { background: #d4623c; }
    .btn-cta:active { transform: scale(0.99); }
    .btn-cta:disabled { opacity: 0.6; cursor: not-allowed; }
    .form-fine {
      text-align: center;
      font-size: 0.78rem;
      color: #999;
      margin-top: 12px;
    }
    .success-msg {
      background: #f0faf4;
      border: 1.5px solid #6fcf97;
      border-radius: 10px;
      padding: 20px;
      text-align: center;
      color: #1a7a44;
      font-weight: 500;
      display: none;
    }
    .error-msg {
      background: #fff0f0;
      border: 1.5px solid #f5a0a0;
      border-radius: 8px;
      padding: 10px 14px;
      color: #c0392b;
      font-size: 0.85rem;
      margin-bottom: 12px;
      display: none;
    }

    /* WHAT YOU GET */
    .section {
      max-width: 900px;
      margin: 60px auto;
      padding: 0 24px;
    }
    .section-label {
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #e8714a;
      margin-bottom: 12px;
    }
    .section h2 {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: clamp(1.4rem, 3vw, 2rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      color: #0f0f1a;
      margin-bottom: 32px;
    }
    .what-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 20px;
    }
    .what-item {
      background: #f8f9fc;
      border: 1px solid #e8eaf0;
      border-radius: 12px;
      padding: 24px;
    }
    .what-icon {
      font-size: 1.5rem;
      margin-bottom: 10px;
    }
    .what-item h3 {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 1rem;
      font-weight: 700;
      margin-bottom: 8px;
      color: #0f0f1a;
    }
    .what-item p {
      font-size: 0.88rem;
      color: #666;
      line-height: 1.6;
    }

    /* HOW IT WORKS */
    .steps {
      display: flex;
      flex-direction: column;
      gap: 0;
      max-width: 600px;
    }
    .step {
      display: flex;
      gap: 20px;
      align-items: flex-start;
      padding: 20px 0;
      border-bottom: 1px solid #f0f0f0;
    }
    .step:last-child { border-bottom: none; }
    .step-num {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: #e8714a;
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 800;
      font-size: 0.9rem;
      flex-shrink: 0;
    }
    .step-text h3 {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 700;
      font-size: 0.95rem;
      margin-bottom: 4px;
      color: #0f0f1a;
    }
    .step-text p {
      font-size: 0.85rem;
      color: #666;
      line-height: 1.6;
    }

    /* SOCIAL PROOF */
    .proof-bar {
      background: #f8f9fc;
      border-top: 1px solid #e8eaf0;
      border-bottom: 1px solid #e8eaf0;
      padding: 32px 24px;
      margin: 40px 0;
    }
    .proof-inner {
      max-width: 900px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 24px;
    }
    .proof-stats {
      display: flex;
      gap: 40px;
      flex-wrap: wrap;
      justify-content: center;
    }
    .stat { text-align: center; }
    .stat-num {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 2rem;
      font-weight: 800;
      color: #e8714a;
      display: block;
    }
    .stat-label {
      font-size: 0.82rem;
      color: #666;
    }
    .testimonial {
      background: #fff;
      border: 1px solid #e8eaf0;
      border-radius: 12px;
      padding: 24px;
      max-width: 560px;
      margin: 0 auto;
      text-align: center;
    }
    .testimonial blockquote {
      font-size: 0.95rem;
      color: #333;
      line-height: 1.7;
      font-style: italic;
      margin-bottom: 12px;
    }
    .testimonial cite {
      font-size: 0.82rem;
      color: #888;
      font-style: normal;
    }

    /* PRICING PREVIEW */
    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 16px;
    }
    .plan {
      border: 1.5px solid #e8eaf0;
      border-radius: 12px;
      padding: 24px;
      position: relative;
    }
    .plan.featured {
      border-color: #e8714a;
      background: #fff8f5;
    }
    .plan-badge {
      position: absolute;
      top: -12px;
      left: 50%;
      transform: translateX(-50%);
      background: #e8714a;
      color: #fff;
      font-size: 0.72rem;
      font-weight: 700;
      padding: 3px 12px;
      border-radius: 100px;
      white-space: nowrap;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .plan h3 {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 800;
      font-size: 1.1rem;
      margin-bottom: 4px;
    }
    .plan-price {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 1.5rem;
      font-weight: 800;
      color: #e8714a;
      margin-bottom: 16px;
    }
    .plan-price span {
      font-size: 0.85rem;
      color: #888;
      font-weight: 500;
    }
    .plan ul {
      list-style: none;
      font-size: 0.85rem;
      color: #555;
      line-height: 1.8;
    }
    .plan li::before {
      content: "✓ ";
      color: #e8714a;
      font-weight: 700;
    }

    /* BOTTOM CTA */
    .bottom-cta {
      background: #0f0f1a;
      color: #fff;
      text-align: center;
      padding: 60px 24px;
      margin-top: 60px;
    }
    .bottom-cta h2 {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: clamp(1.5rem, 3vw, 2.2rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      margin-bottom: 12px;
    }
    .bottom-cta p {
      color: #aaa;
      margin-bottom: 28px;
      font-size: 0.95rem;
    }
    .btn-cta-dark {
      display: inline-block;
      background: #e8714a;
      color: #fff;
      padding: 16px 36px;
      border-radius: 10px;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 700;
      font-size: 1rem;
      text-decoration: none;
      transition: background 0.2s;
    }
    .btn-cta-dark:hover { background: #d4623c; }

    /* SAMPLE AUDIT */
    .sample-wrapper {
      border: 1.5px solid #e8eaf0;
      border-radius: 14px;
      overflow: hidden;
    }
    .sample-banner {
      background: #fff8f0;
      border-bottom: 1.5px solid #fde8d4;
      padding: 10px 20px;
      font-size: 0.82rem;
      color: #b85c28;
      font-weight: 500;
      text-align: center;
    }
    .sample-audit {
      padding: 28px;
      background: #fff;
    }
    .sample-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 24px;
      padding-bottom: 20px;
      border-bottom: 1px solid #f0f0f0;
    }
    .sample-site {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 800;
      font-size: 1.1rem;
      color: #0f0f1a;
    }
    .sample-date { font-size: 0.8rem; color: #999; margin-top: 2px; }
    .sample-score-wrap { text-align: center; }
    .sample-score {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 2.2rem;
      font-weight: 800;
      color: #e8714a;
      line-height: 1;
    }
    .sample-score-label { font-size: 0.75rem; color: #999; margin-top: 2px; }
    .sample-section-title {
      font-size: 0.82rem;
      font-weight: 700;
      color: #444;
      margin: 20px 0 10px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .issue-list { display: flex; flex-direction: column; gap: 10px; }
    .issue {
      border: 1px solid #e8eaf0;
      border-radius: 10px;
      padding: 14px 16px;
    }
    .issue.high { border-left: 3px solid #ef4444; }
    .issue.medium { border-left: 3px solid #f59e0b; }
    .issue-meta {
      display: flex;
      gap: 8px;
      margin-bottom: 6px;
    }
    .issue-priority {
      font-size: 0.72rem;
      font-weight: 700;
      padding: 2px 8px;
      border-radius: 4px;
      letter-spacing: 0.04em;
    }
    .high-p { background: #fef2f2; color: #ef4444; }
    .med-p { background: #fffbeb; color: #d97706; }
    .issue-cat {
      font-size: 0.72rem;
      color: #999;
      padding: 2px 8px;
      background: #f5f5f5;
      border-radius: 4px;
    }
    .issue-title {
      font-weight: 600;
      font-size: 0.9rem;
      color: #0f0f1a;
      margin-bottom: 6px;
    }
    .issue-detail {
      font-size: 0.82rem;
      color: #555;
      line-height: 1.6;
      margin-bottom: 6px;
    }
    .issue-urls {
      font-size: 0.75rem;
      color: #999;
      font-family: monospace;
    }
    .content-recs { display: flex; flex-direction: column; gap: 10px; }
    .rec {
      display: flex;
      gap: 14px;
      align-items: flex-start;
      padding: 12px 14px;
      background: #f8f9fc;
      border-radius: 8px;
    }
    .rec-num {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 800;
      font-size: 1.1rem;
      color: #e8714a;
      flex-shrink: 0;
      width: 28px;
    }
    .rec-title {
      font-weight: 600;
      font-size: 0.88rem;
      color: #0f0f1a;
      margin-bottom: 3px;
    }
    .rec-why { font-size: 0.78rem; color: #777; }
    .sample-footer {
      margin-top: 20px;
      padding-top: 16px;
      border-top: 1px solid #f0f0f0;
      font-size: 0.78rem;
      color: #999;
      line-height: 1.6;
      text-align: center;
    }

    /* FORM TABS */
    .form-tabs {
      display: flex;
      gap: 0;
      margin: -32px -32px 24px;
      border-bottom: 1px solid #e8eaf0;
      background: #f8f9fc;
      border-radius: 14px 14px 0 0;
      overflow: hidden;
    }
    .form-tab {
      flex: 1;
      padding: 14px 12px;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.82rem;
      font-weight: 700;
      border: none;
      background: transparent;
      color: #999;
      cursor: pointer;
      border-bottom: 2px solid transparent;
      transition: all 0.2s;
    }
    .form-tab.active {
      color: #e8714a;
      background: #fff;
      border-bottom-color: #e8714a;
    }
    .form-tab:hover:not(.active) { color: #555; background: #f0f1f5; }

    /* SIGNUP PANEL */
    .signup-intro {
      font-size: 0.85rem;
      color: #777;
      margin-bottom: 16px;
      line-height: 1.6;
    }
    .signup-plans {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-bottom: 4px;
    }
    .signup-plan {
      cursor: pointer;
      position: relative;
    }
    .signup-plan input[type="radio"] { display: none; }
    .signup-plan-inner {
      border: 1.5px solid #e8eaf0;
      border-radius: 10px;
      padding: 14px 12px;
      transition: border-color 0.2s;
      position: relative;
    }
    .signup-plan.selected .signup-plan-inner,
    .signup-plan input:checked ~ .signup-plan-inner {
      border-color: #e8714a;
      background: #fff8f5;
    }
    .signup-plan-badge {
      font-size: 0.65rem;
      font-weight: 700;
      color: #e8714a;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 4px;
    }
    .signup-plan-name {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 700;
      font-size: 0.88rem;
      color: #0f0f1a;
      margin-bottom: 2px;
    }
    .signup-plan-price {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 800;
      font-size: 1.1rem;
      color: #e8714a;
      margin-bottom: 4px;
    }
    .signup-plan-price span { font-size: 0.72rem; color: #999; font-weight: 500; }
    .signup-plan-desc { font-size: 0.72rem; color: #777; line-height: 1.4; }

    @media (max-width: 640px) {
      .proof-stats { gap: 24px; }
      .form-card { padding: 24px; }
      .form-tabs { margin: -24px -24px 20px; }
      .sample-audit { padding: 16px; }
      .sample-header { flex-direction: column; gap: 12px; align-items: flex-start; }
      .signup-plans { grid-template-columns: 1fr; }
    }
  </style>
</head>
<!-- PATH SELECTOR BANNER -->
<div style="background: #f1f5f9; border-bottom: 1px solid #e2e8f0; padding: 12px 20px; text-align: center; font-size: 0.88rem; color: #475569;">
  Looking for our <strong>self-serve SEO platform</strong> ($49–$199/mo)? <a href="/pricing" style="color: #e8714a; font-weight: 600; text-decoration: none;">View SaaS pricing →</a>
</div>

<body>

<!-- NAV -->
<nav>
  <a href="/" class="logo">meridian<span>.</span></a>
  <span class="nav-trust">No spam. No commitment.</span>
</nav>

<!-- HERO -->
<section class="hero">
  <span class="badge">Agency Services — Done With You</span>
  <h1>Find out <em>exactly</em> why your site isn't ranking</h1>
  <p class="hero-sub">
    We audit your site against 40+ ranking factors and send you a prioritized fix list — free, in 24 hours. <strong>Or hire us</strong> to implement everything: hands-on SEO from $1,500/mo.
  </p>

  <!-- FORM TABS -->
  <div class="form-card">
    <div class="form-tabs">
      <button class="form-tab active" id="tab-audit" type="button" onclick="switchTab('audit')">Get free audit</button>
      <button class="form-tab" id="tab-signup" type="button" onclick="switchTab('signup')">Agency Services — from $1,500/mo</button>
    </div>

    <!-- AUDIT TAB -->
    <div id="panel-audit">
      <div class="error-msg" id="error-msg"></div>
      <div id="form-area">
        <div class="form-row">
          <label class="form-label" for="name">Your name</label>
          <input type="text" id="name" placeholder="Jane Smith" autocomplete="name" />
        </div>
        <div class="form-row">
          <label class="form-label" for="email">Work email</label>
          <input type="email" id="email" placeholder="jane@company.com" autocomplete="email" />
        </div>
        <div class="form-row">
          <label class="form-label" for="website">Your website</label>
          <input type="url" id="website" placeholder="https://yoursite.com" />
        </div>
        <button class="btn-cta" id="submit-btn" type="button">
          Get my free SEO audit →
        </button>
        <p class="form-fine">Takes 30 seconds. Results in your inbox within 24 hours.</p>
      </div>
      <div class="success-msg" id="success-msg">
        ✅ Got it! Your audit is in the queue.<br/>
        <strong>Check your inbox in the next 24 hours.</strong><br/>
        <span style="font-size:0.85rem; color: #555; margin-top: 8px; display:block;">We'll send a full breakdown of what's hurting your rankings and a prioritized fix list.</span>
      </div>
    </div>

    <!-- SIGNUP TAB -->
    <div id="panel-signup" style="display:none;">
      <p class="signup-intro">Choose your plan and get started today. Every plan includes the full site audit on day one.</p>
      <div class="signup-plans">
        <label class="signup-plan" id="plan-foundation">
          <input type="radio" name="plan" value="foundation" />
          <div class="signup-plan-inner">
            <div class="signup-plan-name">Foundation</div>
            <div class="signup-plan-price">$1,500<span>/mo</span></div>
            <div class="signup-plan-desc">Daily tech audits, rank tracking, weekly report</div>
          </div>
        </label>
        <label class="signup-plan selected" id="plan-growth">
          <input type="radio" name="plan" value="growth" checked />
          <div class="signup-plan-inner">
            <div class="signup-plan-badge">Most popular</div>
            <div class="signup-plan-name">Growth</div>
            <div class="signup-plan-price">$3,000<span>/mo</span></div>
            <div class="signup-plan-desc">+ Content creation, 2 drafts/week, trend scout</div>
          </div>
        </label>
        <label class="signup-plan" id="plan-authority">
          <input type="radio" name="plan" value="authority" />
          <div class="signup-plan-inner">
            <div class="signup-plan-name">Authority</div>
            <div class="signup-plan-price">$5,000<span>/mo</span></div>
            <div class="signup-plan-desc">+ Link building, competitor gap analysis</div>
          </div>
        </label>
      </div>
      <div class="form-row" style="margin-top:20px;">
        <label class="form-label" for="su-name">Your name</label>
        <input type="text" id="su-name" placeholder="Jane Smith" autocomplete="name" />
      </div>
      <div class="form-row">
        <label class="form-label" for="su-email">Work email</label>
        <input type="email" id="su-email" placeholder="jane@company.com" autocomplete="email" />
      </div>
      <div class="form-row">
        <label class="form-label" for="su-website">Your website</label>
        <input type="url" id="su-website" placeholder="https://yoursite.com" />
      </div>
      <div class="error-msg" id="su-error-msg"></div>
      <button class="btn-cta" id="su-submit-btn" type="button">
        Start my plan →
      </button>
      <p class="form-fine">We'll reach out within 2 hours to confirm and schedule onboarding.</p>
      <div class="success-msg" id="su-success-msg">
