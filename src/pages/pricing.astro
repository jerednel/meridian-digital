            </li>
          </ul>
        </div>

      </div>
      
      <!-- Risk Reversal -->
      <div class="mt-12 text-center max-w-2xl mx-auto">
        <div class="flex flex-wrap items-center justify-center gap-6 text-sm">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-dark">14-day free trial</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-dark">No credit card required</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-dark">Cancel anytime</span>
          </div>
        </div>      
      </div>
    </div>
  </section>

  <!-- Comparison Section: Why Meridian Wins -->
  <section class="bg-dark py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-6">
      <h2 class="text-3xl md:text-4xl font-semibold text-hero-text leading-tight text-center mb-12">What you get vs alternatives</h2>
      
      <div class="grid md:grid-cols-3 gap-8">
        
        <!-- vs DIY -->
        <div class="bg-dark-card rounded-2xl p-8 border border-dark-border">
          <div class="text-sm font-medium text-body-muted mb-4">VS DOING IT YOURSELF</div>
          <h3 class="text-xl font-bold text-hero-text mb-4">Stop trying to be an SEO expert.</h3>
          <p class="text-body-muted mb-6">Learning SEO, staying current with algorithm updates, and executing daily takes 10+ hours/week. Meridian runs 24/7. You focus on your business.</p>
          <div class="space-y-3 text-sm">
            <div class="flex justify-between">
              <span class="text-body-muted">Your time</span>
              <span class="text-red-400">10+ hrs/week</span>
            </div>
            <div class="flex justify-between">
              <span class="text-body-muted">Meridian</span>
              <span class="text-green-400">15 min/week</span>
            </div>
          </div>
        </div>

        <!-- vs Tools -->
        <div class="bg-dark-card rounded-2xl p-8 border border-dark-border">
          <div class="text-sm font-medium text-body-muted mb-4">VS SEO TOOLS</div>
          <h3 class="text-xl font-bold text-hero-text mb-4">Data without execution is useless.</h3>
          <p class="text-body-muted mb-6">Semrush ($200/mo) + Surfer ($50/mo) + Clearscope ($170/mo) = $420/mo for tools that show you what to do. Meridian does it for $99.</p>
          <div class="space-y-3 text-sm">
            <div class="flex justify-between">
              <span class="text-body-muted">Tool stack</span>
              <span class="text-red-400">$420+/mo + your time</span>
            </div>
            <div class="flex justify-between">
              <span class="text-body-muted">Meridian Growth</span>
              <span class="text-green-400">$99/mo, done for you</span>
            </div>
          </div>
        </div>

        <!-- vs Agencies -->
        <div class="bg-dark-card rounded-2xl p-8 border border-dark-border">
          <div class="text-sm font-medium text-body-muted mb-4">VS AGENCIES</div>
          <h3 class="text-xl font-bold text-hero-text mb-4">Same results. 3% of the cost.</h3>
          <p class="text-body-muted mb-6">SEO agencies charge $3,000+/mo for monthly reports. Meridian executes daily for $49-199/mo. Better execution, fraction of the price.</p>
          <div class="space-y-3 text-sm">
            <div class="flex justify-between">
              <span class="text-body-muted">Agency retainer</span>
              <span class="text-red-400">$3,000+/mo</span>
            </div>
            <div class="flex justify-between">
              <span class="text-body-muted">Meridian Pro</span>
              <span class="text-green-400">$199/mo, 24/7 execution</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="bg-white py-16 md:py-24">
    <div class="mx-auto max-w-3xl px-6">
      <h2 class="text-3xl md:text-4xl font-semibold text-dark leading-tight text-center mb-12">Frequently asked questions</h2>
      
      <div class="space-y-6">
        <div class="border-b border-gray-200 pb-6">
          <h3 class="text-lg font-semibold text-dark mb-2">What results can I expect?</h3>
          <p class="text-light-text leading-relaxed">Most users see 5+ critical SEO issues fixed in their first week. Ranking improvements typically appear within 30 days. We guarantee results: if you don't see measurable improvement in 30 days, we'll refund 100% of your payment.</p>
        </div>
        
        <div class="border-b border-gray-200 pb-6">
          <h3 class="text-lg font-semibold text-dark mb-2">How is this different from Semrush or Ahrefs?</h3>
          <p class="text-light-text leading-relaxed">SEO tools show you data. Meridian executes. We don't just tell you what's wrong—we deliver copy-paste fixes, write content drafts, and monitor your rankings daily. Think of us as an AI SEO team, not a dashboard.</p>
        </div>
        
        <div class="border-b border-gray-200 pb-6">
          <h3 class="text-lg font-semibold text-dark mb-2">What's included in the free trial?</h3>
          <p class="text-light-text leading-relaxed">Full access to everything in your chosen plan for 14 days. Daily audits, content drafts, rank tracking—the complete platform. No credit card required to start. If you don't continue, your trial simply ends.</p>
        </div>
        
        <div class="border-b border-gray-200 pb-6">
          <h3 class="text-lg font-semibold text-dark mb-2">How does the money-back guarantee work?</h3>
          <p class="text-light-text leading-relaxed">If you're not satisfied within 30 days of your first paid invoice, contact us for a full refund—no questions asked. We're confident in our results, so we make it risk-free for you.</p>
        </div>
        
        <div class="border-b border-gray-200 pb-6">
          <h3 class="text-lg font-semibold text-dark mb-2">Can I switch plans?</h3>
          <p class="text-light-text leading-relaxed">Yes, anytime. Upgrade for immediate access to more features. Downgrade takes effect at your next billing cycle. No penalties, no hassle.</p>
        </div>
        
        <div>
          <h3 class="text-lg font-semibold text-dark mb-2">What if I need hands-on help?</h3>
          <p class="text-light-text leading-relaxed">Our "Done With You" agency service provides direct strategy and implementation support. <a href="/agency" class="text-accent hover:text-accent-hover font-medium transition-colors">Learn more about agency services</a>.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="bg-gradient-to-br from-dark to-dark-card py-24 md:py-32">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <h2 class="text-3xl md:text-[44px] font-semibold text-hero-text leading-tight">Ready to stop reading reports and start ranking?</h2>
      <p class="mt-6 text-body-muted text-lg max-w-xl mx-auto leading-relaxed">
        Join businesses saving $30,000+/year on SEO. 14-day free trial. 30-day money-back guarantee.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a href="https://app.bymeridian.com/auth/register?plan=growth" class="inline-flex items-center px-8 py-4 bg-accent hover:bg-accent-hover text-white font-medium rounded-lg transition-colors">
          Start free trial
        </a>
        <a href="/audit" class="inline-flex items-center px-8 py-4 border border-dark-border text-body-muted hover:text-white hover:border-white/20 font-medium rounded-lg transition-colors">
          Get free audit first
        </a>
      </div>
      <p class="mt-6 text-sm text-body-muted">
        No credit card required · Cancel anytime · Rankings or refund
      </p>
    </div>
  </section>

  <script>
    // Billing Toggle Logic
    const toggle = document.getElementById('billing-toggle');
    const indicator = document.getElementById('toggle-indicator');
    const priceAmounts = document.querySelectorAll('.price-amount');
    const pricePeriods = document.querySelectorAll('.price-period');
    const annualSavings = document.querySelectorAll('.annual-savings');
    
    let isAnnual = false;
    
    toggle.addEventListener('click', () => {
      isAnnual = !isAnnual;
      
      // Update toggle visual
      toggle.setAttribute('aria-pressed', isAnnual.toString());
      indicator.style.transform = isAnnual ? 'translateX(28px)' : 'translateX(0)';
      toggle.classList.toggle('bg-accent', isAnnual);
      toggle.classList.toggle('bg-dark-border', !isAnnual);
      
      // Update prices
      priceAmounts.forEach(el => {
        const monthly = el.getAttribute('data-monthly');
        const annual = el.getAttribute('data-annual');
        el.textContent = `$${isAnnual ? annual : monthly}`;
      });
      
      // Update period text
      pricePeriods.forEach(el => {
        el.textContent = isAnnual ? '/yr' : '/mo';
      });
      
      // Show/hide annual savings
      annualSavings.forEach(el => {
        el.classList.toggle('hidden', !isAnnual);
      });
    });
  </script>

</Layout>
