                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="font-medium text-dark">Everything in Starter</span>
            </li>
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              Up to 200 pages monitored
            </li>
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              100 keywords tracked
            </li>
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              8 content drafts / month
            </li>
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              Copy-paste technical fixes
            </li>
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              Competitor tracking (3 sites)
            </li>
          </ul>
        </div>

        <!-- Pro -->
        <div class="border border-gray-200 rounded-2xl p-8 flex flex-col">
          <div class="mb-6">
            <h3 class="text-xl font-bold text-dark">Pro</h3>
            <p class="text-sm text-light-text mt-1">For agencies & high-growth companies</p>
          </div>
          <div class="mb-6">
            <div class="flex items-baseline gap-2">
