---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Pricing — SEO That Pays for Itself" 
  description="Meridian delivers agency-level SEO execution at 3% of the cost. 14-day free trial. 30-day money-back guarantee. Plans from $49/mo."
>

  <!-- ROI Hero -->
  <section class="relative pt-28 pb-20 bg-gradient-to-b from-dark to-dark-card">
