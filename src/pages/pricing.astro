---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Pricing — Meridian SEO Platform" 
  description="Transparent pricing for the Meridian SEO platform. Start with a 14-day free trial. Starter ($49/mo), Growth ($99/mo), Pro ($199/mo)."
>

  <!-- Agency Services Banner -->
  <div class="bg-accent/10 border-b border-accent/20 py-3 text-center">
    <p class="text-sm text-body-muted">
      Looking for <strong class="text-accent">hands-on agency support</strong>? 
      <a href="/agency" class="text-accent font-semibold hover:underline">View our Done-With-You services →</a>
    </p>
  </div>

  <!-- Hero -->
  <section class="relative pt-28 pb-20 bg-gradient-to-b from-dark to-dark-card">
    <div class="mx-auto max-w-7xl px-6 text-center">
      <p class="text-xs font-medium uppercase tracking-[0.2em] text-accent mb-6">Simple, Transparent Pricing</p>
      <h1 class="text-4xl md:text-6xl font-extrabold text-hero-text leading-[1.05] tracking-tight max-w-3xl mx-auto">
        Choose your level of SEO coverage
      </h1>
      <p class="mt-6 text-lg text-body-muted max-w-2xl mx-auto leading-relaxed">
        Start with a 14-day free trial. No credit card required. Scale up or down anytime.
      </p>
    </div>
  </section>

  <!-- Pricing Cards -->
  <section class="bg-white py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-6">
      
      <!-- Billing Toggle -->
      <div class="flex items-center justify-center gap-4 mb-12">
        <span class="text-sm font-medium text-light-text" id="monthly-label">Monthly</span>
        <button 
          id="billing-toggle"
          class="relative w-14 h-7 rounded-full bg-dark-border transition-colors focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2"
          aria-label="Toggle annual billing"
          aria-pressed="false"
        >
          <span 
            id="toggle-indicator"
            class="absolute left-1 top-1 w-5 h-5 rounded-full bg-white transition-transform"
          ></span>
        </button>
        <span class="text-sm font-medium text-light-text" id="annual-label">Annual</span>
        <span class="text-xs font-medium text-accent bg-accent/10 px-2 py-1 rounded-full">Save 2 months</span>
      </div>

      <!-- Pricing Grid -->
      <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
        
        <!-- Starter -->
        <div class="border border-gray-200 rounded-2xl p-8 flex flex-col">
          <div class="mb-6">
            <h3 class="text-xl font-bold text-dark">Starter</h3>
            <p class="text-sm text-light-text mt-1">For small sites getting serious about SEO</p>
          </div>
          <div class="mb-6">
            <div class="flex items-baseline gap-2">
              <span class="text-4xl font-extrabold text-dark price-amount" data-monthly="49" data-annual="490">$49</span>
              <span class="text-light-text price-period">/mo</span>
            </div>
            <p class="text-sm text-light-text mt-1 annual-savings hidden">$490/year (save $98)</p>
          </div>
          <a 
            href="/start?plan=starter" 
            class="w-full inline-flex items-center justify-center px-6 py-3 border-2 border-accent text-accent hover:bg-accent hover:text-white text-sm font-medium rounded-lg transition-colors mb-6"
          >
            Start free trial
          </a>
          <ul class="space-y-3 text-[15px] text-light-text flex-grow">
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              Daily technical audits
            </li>
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              Up to 50 pages monitored
            </li>
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
