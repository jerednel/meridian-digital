        </svg>
        <span class="text-sm text-body-muted">30-day money-back guarantee · Rankings or refund</span>
      </div>

      <h1 class="text-4xl md:text-6xl font-extrabold text-hero-text leading-[1.05] tracking-tight max-w-4xl mx-auto">
        SEO execution that pays for itself
      </h1>
      <p class="mt-6 text-lg text-body-muted max-w-2xl mx-auto leading-relaxed">
        Agency-level results. 3% of the cost. Start free for 14 days—no credit card required. See ranking improvements in 30 days or your money back.
      </p>
      
      <!-- ROI Stats -->
      <div class="mt-12 grid grid-cols-3 gap-8 max-w-2xl mx-auto">
        <div>
          <div class="text-3xl md:text-4xl font-bold text-accent">$34K</div>
          <div class="text-sm text-body-muted mt-1">Saved/year vs agencies</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-bold text-accent">5+</div>
          <div class="text-sm text-body-muted mt-1">Issues fixed week 1</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-bold text-accent">30</div>
          <div class="text-sm text-body-muted mt-1">Days to results</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Cards -->
