---
import AppLayout from '../../../layouts/AppLayout.astro';

const apiUrl = import.meta.env.PUBLIC_MERIDIAN_API_URL || 'http://127.0.0.1:3000';
---

<AppLayout title="Verifying login - Meridian" description="Verify your Meridian login link.">
  <div class="app-kicker">secure login</div>
  <h1 class="app-title">Verifying your login link.</h1>
  <p class="app-subtitle" id="message">Hang tight. Meridian is opening your account.</p>

  <script define:vars={{ apiUrl }}>
    const message = document.getElementById('message');
    const params = new URLSearchParams(window.location.search);
    const token = params.get('token');

    async function verify() {
      if (!token) {
        message.textContent = 'This login link is missing a token. Request a fresh link.';
        return;
      }

      try {
        const resp = await fetch(`${apiUrl}/auth/verify`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token }),
        });
        const json = await resp.json();
        if (!resp.ok) throw new Error(json.error || 'Login failed.');
        localStorage.setItem('meridian_session', json.token);
        window.location.href = '/app';
      } catch (error) {
        message.textContent = error.message || 'Login failed. Request a fresh link.';
      }
    }

    verify();
  </script>
</AppLayout>
