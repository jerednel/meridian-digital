---
import AppLayout from '../../layouts/AppLayout.astro';

const apiUrl = import.meta.env.PUBLIC_MERIDIAN_API_URL || 'http://127.0.0.1:3000';
---

<AppLayout title="Dashboard - Meridian" description="Your Meridian AI Search dashboard.">
  <div id="loading">
    <div class="app-kicker">brief</div>
    <h1 class="app-title">Loading your answer-market brief.</h1>
    <p class="app-subtitle">Checking subscription, latest evidence, and generated assets.</p>
  </div>

  <div id="dashboard" class="hidden">
    <section class="brief-hero app-card">
      <div class="brief-copy">
        <div class="app-kicker">AI Search brief</div>
        <h1 class="brief-title" id="dashboard-title">Your answer market.</h1>
        <p class="brief-subtitle" id="dashboard-subtitle"></p>
      </div>
      <div class="brief-actions">
        <a id="primary-asset-link" class="app-button" href="#generated-assets">Review recommended asset</a>
        <button id="run-report" class="app-secondary" type="button">Run fresh brief</button>
        <button id="export-report" class="app-secondary quiet" type="button">Export JSON</button>
      </div>
    </section>
    <div id="run-status" class="app-status"></div>

    <section class="verdict-grid">
      <div class="verdict-card primary">
        <span class="verdict-label help-label">
          <span>What is happening</span>
          <button class="help-dot" type="button" aria-label="What is happening explanation">i</button>
          <span class="help-tip" role="tooltip">Plain-English summary of your current AI-search risk. This is not a live ranking position. It combines the site crawl, prompt map, competitor set, source gaps, and available DataForSEO evidence into a directional read.</span>
        </span>
        <strong id="visibility-verdict">Loading visibility verdict.</strong>
        <p id="visibility-score"></p>
      </div>
      <div class="verdict-card">
        <span class="verdict-label help-label">
          <span>Citation strength</span>
          <button class="help-dot" type="button" aria-label="Citation strength explanation">i</button>
          <span class="help-tip" role="tooltip">How much supporting evidence exists for AI tools to confidently mention or cite you. Strong signals include clear page titles, descriptions, comparison language, schema, FAQs, and neutral third-party references.</span>
        </span>
        <strong id="citation-verdict">Loading source signal.</strong>
        <p id="citation-score"></p>
      </div>
      <div class="verdict-card">
        <span class="verdict-label help-label right-tip">
          <span>Competitor pressure</span>
          <button class="help-dot" type="button" aria-label="Competitor pressure explanation">i</button>
          <span class="help-tip" role="tooltip">How likely competitors are to shape the shortlist when buyers ask AI tools for recommendations. Higher pressure means competitors have clearer comparison, implementation, citation, or category signals than you do.</span>
        </span>
        <strong id="pressure-verdict">Loading pressure signal.</strong>
        <p id="pressure-score"></p>
      </div>
    </section>

    <section class="app-grid brief-grid">
      <div class="app-card next-action-card">
        <div class="section-head">
          <h2 class="help-label">
            <span>Recommended next action</span>
            <button class="help-dot" type="button" aria-label="Recommended next action explanation">i</button>
            <span class="help-tip" role="tooltip">The one page, schema fix, citation target, or asset Meridian believes is most likely to improve your AI-search visibility next. It is ranked from current gaps, not guessed from a generic SEO checklist.</span>
          </h2>
          <span class="pill help-label right-tip">
            <span id="evidence-status">evidence pending</span>
            <button class="help-dot" type="button" aria-label="Evidence status explanation">i</button>
            <span class="help-tip" role="tooltip">Shows whether the brief used collected evidence, such as crawled pages and configured AI visibility data, or whether it is still a strategy-only draft.</span>
          </span>
        </div>
        <h3 id="report-fix">Loading recommended asset.</h3>
        <p id="report-summary"></p>
        <div class="why-box">
          <strong class="help-label">
            <span>Why this is first</span>
            <button class="help-dot" type="button" aria-label="Why this is first explanation">i</button>
            <span class="help-tip" role="tooltip">The reason this fix is ranked ahead of the others. A fix can be first because it fills a missing comparison page, adds proof AI systems can read, or gives buyers a clearer reason to shortlist you.</span>
          </strong>
          <span id="report-gap"></span>
        </div>
        <div class="app-actions">
          <a class="app-button" href="#generated-assets">Open generated asset</a>
          <a class="app-secondary" href="/app/onboarding">Tune inputs</a>
        </div>
      </div>

      <aside class="app-card evidence-card">
        <div class="section-head">
          <h2 class="help-label">
            <span>Evidence</span>
            <button class="help-dot" type="button" aria-label="Evidence explanation">i</button>
            <span class="help-tip" role="tooltip">The inputs Meridian used for this brief: your site, competitor sites, custom buyer questions, generated prompt-map entries, and any configured AI visibility data sources.</span>
          </h2>
          <span class="pill muted-pill help-label right-tip">
            <span id="run-date">first run</span>
            <button class="help-dot" type="button" aria-label="Run date explanation">i</button>
            <span class="help-tip" role="tooltip">When this brief was generated. Future runs should be compared against this date to see whether visibility, sources, and competitor pressure are moving.</span>
          </span>
        </div>
        <div class="key-value">
          <div><strong class="help-label"><span>Lead prompt</span><button class="help-dot" type="button" aria-label="Lead prompt explanation">i</button><span class="help-tip" role="tooltip">The most important buyer question Meridian is using as the anchor for this brief. Think of it as the question a prospect might ask ChatGPT before building a vendor shortlist.</span></strong><span id="report-question"></span></div>
          <div><strong class="help-label"><span>AI answer snapshot</span><button class="help-dot" type="button" aria-label="AI answer snapshot explanation">i</button><span class="help-tip" role="tooltip">A human-readable summary of how Meridian thinks the answer market currently frames you, competitors, and the available evidence. It is a diagnosis, not a verbatim AI answer transcript.</span></strong><span id="report-answer"></span></div>
          <div><strong class="help-label"><span>Prompt map</span><button class="help-dot" type="button" aria-label="Prompt map explanation">i</button><span class="help-tip" role="tooltip">The full set of buyer questions Meridian monitors. It includes your custom questions plus default shortlist, comparison, risk, technical-fit, and procurement questions.</span></strong><span id="account-prompts"></span></div>
          <div><strong class="help-label"><span>Competitors</span><button class="help-dot" type="button" aria-label="Competitors explanation">i</button><span class="help-tip" role="tooltip">The comparison set Meridian uses to judge whether other vendors are easier for AI tools to recommend, compare, or cite.</span></strong><span id="account-competitors"></span></div>
        </div>
        <div class="source-list" id="data-sources"></div>
      </aside>
    </section>

    <section id="generated-assets" class="app-card solution-assets">
      <div class="section-head">
        <div>
          <h2 class="help-label">
            <span>Generated asset workbench</span>
            <button class="help-dot" type="button" aria-label="Generated asset workbench explanation">i</button>
            <span class="help-tip" role="tooltip">Drafts and implementation snippets created from the brief. These are meant to become pages, FAQs, schema, or outreach copy that make your company easier for buyers and AI systems to understand.</span>
          </h2>
          <p class="app-muted">Copy-ready fixes ranked from the current evidence. Start with the recommended tab, then ship the support assets.</p>
        </div>
        <span class="pill help-label right-tip">
          <span id="solution-status">copy ready</span>
          <button class="help-dot" type="button" aria-label="Asset status explanation">i</button>
          <span class="help-tip" role="tooltip">Shows whether Meridian generated usable asset drafts. Copy-ready means the draft is ready for human review and publishing workflow, not that it should bypass editorial approval.</span>
        </span>
      </div>
      <div id="solution-assets"></div>
    </section>

    <section class="app-grid">
      <div class="app-card">
        <div class="section-head">
          <h2 class="help-label">
            <span>Action queue</span>
            <button class="help-dot" type="button" aria-label="Action queue explanation">i</button>
            <span class="help-tip" role="tooltip">A prioritized list of fixes to make your company easier to mention, compare, or cite in AI-assisted buyer research.</span>
          </h2>
          <span class="pill help-label right-tip"><span>ranked fixes</span><button class="help-dot" type="button" aria-label="Ranked fixes explanation">i</button><span class="help-tip" role="tooltip">Ranked by likely usefulness based on current gaps. The list is directional until prompt-level live answer tracking is expanded.</span></span>
        </div>
        <div id="action-queue" class="stack-list"></div>
      </div>

      <div class="app-card">
        <div class="section-head">
          <h2 class="help-label">
            <span>Source gaps</span>
            <button class="help-dot" type="button" aria-label="Source gaps explanation">i</button>
            <span class="help-tip" role="tooltip">Missing proof that makes it harder for AI tools to confidently describe or recommend you. Examples: no comparison page, weak schema, thin FAQs, or not enough neutral third-party sources.</span>
          </h2>
          <span class="pill help-label right-tip"><span>why AI skips you</span><button class="help-dot" type="button" aria-label="Why AI skips you explanation">i</button><span class="help-tip" role="tooltip">AI systems often avoid naming a vendor when the public web does not clearly explain what it does, how it compares, or where neutral sources validate it.</span></span>
        </div>
        <div id="source-gaps" class="stack-list"></div>
      </div>
    </section>

    <section class="app-grid">
      <div class="app-card">
        <h2 class="help-label">
          <span>Prompt map</span>
          <button class="help-dot" type="button" aria-label="Prompt map section explanation">i</button>
          <span class="help-tip" role="tooltip">The buyer questions Meridian uses to simulate how prospects research your category. These are not keywords; they are full questions someone might ask an AI assistant.</span>
        </h2>
        <div id="prompt-map" class="prompt-grid"></div>
      </div>

      <div class="app-card">
        <h2 class="help-label">
          <span>Competitive answer surface</span>
          <button class="help-dot" type="button" aria-label="Competitive answer surface explanation">i</button>
          <span class="help-tip" role="tooltip">How easy each tracked company is for AI systems to understand and compare from public evidence. It is a readiness diagnostic, not proof of live ranking position.</span>
        </h2>
        <div id="competitor-rows" class="table-list"></div>
      </div>
    </section>

    <details id="admin-panel" class="admin-drawer hidden">
      <summary>Admin tier preview</summary>
      <section class="app-card">
        <div class="section-head">
          <h2>Tier preview</h2>
          <span class="pill">Jeremy only</span>
        </div>
        <p class="app-muted">Switch this workspace between SaaS tiers to inspect plan limits, dashboard copy, and onboarding behavior.</p>
        <form id="admin-plan-form" class="app-form compact-form">
          <label>
            Preview tier
            <select name="plan">
              <option value="starter">Starter - $49/mo</option>
              <option value="monitor">Monitor - $99/mo</option>
              <option value="growth">Growth - $249/mo</option>
              <option value="diagnostic">Diagnostic - $750 one-time</option>
              <option value="operator">Operator - $1,000/mo</option>
              <option value="partner">Partner - $2,500/mo</option>
            </select>
          </label>
          <button class="app-secondary" type="submit">Apply preview tier</button>
        </form>
        <div id="admin-status" class="app-status"></div>
      </section>
    </details>
  </div>

  <div id="empty" class="hidden">
    <div class="app-kicker" id="empty-kicker">no monitor yet</div>
    <h1 class="app-title" id="empty-title">Start with a paid monitor.</h1>
    <p class="app-subtitle" id="empty-copy">Your account exists, but there is no active AI Search monitor attached yet.</p>
    <a class="app-button" href="/ai-search#plans">Choose a plan</a>
  </div>

  <script define:vars={{ apiUrl }}>
    const token = localStorage.getItem('meridian_session');
    if (!token) window.location.href = '/app/login';
    let currentReport = null;

    const text = (id, value) => {
      const element = document.getElementById(id);
      if (element) element.textContent = value || 'Not set';
    };

    const html = (id, value) => {
      const element = document.getElementById(id);
      if (element) element.innerHTML = value || 'Not set';
    };

    const escape = (value) => String(value ?? '').replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    })[char]);

    const number = (value) => Number.isFinite(Number(value)) ? Number(value) : 0;

    function help(label, body, position = '') {
      return `
        <span class="help-label ${position}">
          <span>${escape(label)}</span>
          <button class="help-dot" type="button" aria-label="${escape(label)} explanation">i</button>
          <span class="help-tip" role="tooltip">${escape(body)}</span>
        </span>
      `;
    }

    function iconHelp(body, position = '') {
      return `
        <span class="help-label ${position}">
          <button class="help-dot" type="button" aria-label="Explanation">i</button>
          <span class="help-tip" role="tooltip">${escape(body)}</span>
        </span>
      `;
    }

    function scoreTone(score, goodLabel, mixedLabel, weakLabel) {
      if (score >= 70) return goodLabel;
      if (score >= 45) return mixedLabel;
      return weakLabel;
    }

    function renderVerdicts(report) {
      const promptCount = report.prompt_map?.length || report.plan_features?.prompts || 0;
      const competitorCount = report.competitor_rows?.filter((row) => row.domain !== report.website).length || report.competitors?.length || 0;
      const sourceCount = report.data_sources?.length || report.source_gaps?.length || 0;
      const visibility = number(report.visibility_score);
      const citation = number(report.citation_score);
      const pressure = number(report.competitor_pressure);

      text('visibility-verdict', scoreTone(
        visibility,
        `Strong answer-readiness for the tracked prompt set.`,
        `Partial answer-readiness for the tracked prompt set.`,
        `Buyers can miss you across the tracked prompt set.`,
      ));
      html('visibility-score', `${escape(`${visibility}/100 modeled readiness · ${promptCount || 0} prompt-map entries`)} ${iconHelp('This score is a model Meridian calculates from page readiness, source gaps, competitor count, and available AI-visibility evidence. It is directional and should be read with the recommended action, not as a live ranking report.', 'right-tip')}`);
      text('citation-verdict', scoreTone(
        citation,
        `${sourceCount || 'Enough'} source signals support the answer.`,
        'Citations are present but not yet durable.',
        'Citation support is thin for AI answers.',
      ));
      html('citation-score', `${escape(`${citation}/100 citation strength`)} ${iconHelp('A low citation score means the public web may not give AI systems enough trustworthy material to cite you. Publishing clear pages, schema, FAQs, and earning neutral mentions should raise this over time.', 'right-tip')}`);
      text('pressure-verdict', scoreTone(
        100 - pressure,
        'Competitors are not dominating the answer surface.',
        `${competitorCount || 'Tracked'} competitors still shape the shortlist.`,
        'Competitors are likely shaping buyer shortlists.',
      ));
      html('pressure-score', `${escape(`${pressure}/100 competitor pressure`)} ${iconHelp('Higher pressure means competitors look easier to recommend from public evidence. This score rises when there are more tracked competitors or when their pages look clearer than yours.', 'right-tip')}`);
      text('run-date', report.generated_at ? `run ${new Date(report.generated_at).toLocaleDateString()}` : 'first run');
    }

    const countList = (value) => String(value || '')
      .split(/\n|,/)
      .map((item) => item.trim())
      .filter(Boolean)
      .length;

    function renderReport(report) {
      if (!report) return;
      currentReport = report;
      renderVerdicts(report);
      text('report-summary', report.summary);
      text('report-question', report.question);
      text('report-answer', report.answer_surface);
      text('report-gap', report.source_gap);
      text('report-fix', report.next_fix);
      text('evidence-status', (report.evidence_status || 'starter').replaceAll('_', ' '));

      document.getElementById('data-sources').innerHTML = (report.data_sources || [])
        .map((source) => `<div><span>${escape(source.label)}</span><strong>${help(source.status, 'Collected means this evidence source was available for the current brief. Unavailable or not configured means Meridian used the other available evidence and marked the gap.', 'right-tip')}</strong></div>`)
        .join('') || '<p class="app-muted">No evidence sources have been collected yet.</p>';

      document.getElementById('action-queue').innerHTML = (report.action_queue || [])
        .map((item) => `
          <article>
            <span class="rank">${escape(item.priority)}</span>
            <div>
              <h3>${help(item.asset_type || 'Action', 'The kind of fix Meridian recommends shipping. Examples include comparison pages, implementation guides, schema, or citation outreach.')}</h3>
              <p>${escape(item.action)}</p>
              <small>${escape(item.expected_effect || '')}</small>
            </div>
          </article>
        `)
        .join('') || '<p class="app-muted">Complete onboarding to generate the action queue.</p>';

      document.getElementById('source-gaps').innerHTML = (report.source_gaps || [])
        .map((item) => `
          <article>
            <div>
              <h3>${escape(item.gap)}</h3>
              <p>${escape(item.diagnosis)}</p>
              <small>${escape(item.why_it_matters)}</small>
            </div>
          </article>
        `)
        .join('') || '<p class="app-muted">No gaps available yet.</p>';

      document.getElementById('prompt-map').innerHTML = (report.prompt_map || [])
        .map((prompt) => `
          <div class="prompt-card">
            <span>${help(prompt.priority || 'medium', 'Priority reflects how important this buyer question is for shortlist formation. High-priority prompts are the questions most likely to affect whether you are considered.')}</span>
            <p>${escape(prompt.question)}</p>
            <small>${escape(prompt.intent || 'buyer intent')}</small>
          </div>
        `)
        .join('') || '<p class="app-muted">No prompt map available yet.</p>';

      document.getElementById('competitor-rows').innerHTML = (report.competitor_rows || [])
        .map((row) => `
          <div>
            <strong>${escape(row.domain)}</strong>
            <span>${escape(row.role)}</span>
            <span>${help(`${escape(row.answer_readiness)}/100`, 'Answer-readiness is a modeled score for how easy this company is to understand, compare, and cite from public evidence. It is not a live AI ranking.')}</span>
            <p>${escape(row.likely_strength)}. ${escape(row.missing_asset)}</p>
          </div>
        `)
        .join('') || '<p class="app-muted">Add competitors to compare answer readiness.</p>';

      renderSolutionAssets(report.solution_assets);
    }

    function renderSolutionAssets(assets) {
      const target = document.getElementById('solution-assets');
      if (!assets) {
        target.innerHTML = '<p class="app-muted">Run a fresh brief to generate implementation-ready assets.</p>';
        return;
      }
      text('solution-status', assets.status || 'generated');
      const page = assets.comparison_page || {};
      const sections = (page.sections || [])
        .map((section) => `
          <article class="asset-section">
            <h3>${escape(section.heading)}</h3>
            <p>${escape(section.body)}</p>
          </article>
        `)
        .join('');
      const table = (page.comparison_table || [])
        .map((row) => `
          <div>
            <strong>${escape(row.criterion)}</strong>
            <span>${escape(row.recommended_copy)}</span>
          </div>
        `)
        .join('');
      const faq = (assets.faq || [])
        .map((item) => `
          <article>
            <h3>${escape(item.question)}</h3>
            <p>${escape(item.answer)}</p>
          </article>
        `)
        .join('');
      const snippets = (assets.implementation_snippets || [])
        .map((snippet, index) => renderCodeBlock(snippet.label, snippet.code, snippet.language, `snippet-${index}`))
        .join('');
      const pageCopy = [
        page.title,
        page.meta_description,
        page.h1,
        page.intro,
        ...(page.sections || []).map((section) => `${section.heading}\n${section.body}`),
        page.cta,
      ].filter(Boolean).join('\n\n');

      target.innerHTML = `
        <div class="asset-tabs" role="tablist" aria-label="Generated assets">
          <button class="asset-tab active" type="button" data-asset-tab="comparison">Comparison page</button>
          <button class="asset-tab" type="button" data-asset-tab="faq">FAQ</button>
          <button class="asset-tab" type="button" data-asset-tab="schema">Schema</button>
          <button class="asset-tab" type="button" data-asset-tab="pitch">Citation pitch</button>
          <button class="asset-tab" type="button" data-asset-tab="implementation">Implementation</button>
        </div>

        <article class="asset-panel asset-pane active" data-asset-pane="comparison">
          <div class="asset-meta">
            <span class="asset-status">Ready to publish · ${escape(page.slug || '/comparison')}</span>
            <button class="copy-button" type="button" data-copy="${escape(pageCopy)}">Copy page draft</button>
          </div>
          <h3>${escape(page.title || 'Comparison page draft')}</h3>
          <p class="asset-description">${escape(page.meta_description || '')}</p>
          <div class="asset-why">
            <strong>Why this asset is first</strong>
            <span>It creates comparison-friendly source material AI systems can cite when buyers ask vendor-shortlist questions.</span>
          </div>
          <h4>${escape(page.h1 || '')}</h4>
          <p class="asset-copy">${escape(page.intro || '')}</p>
          <div class="asset-section-list">${sections}</div>
          <div class="asset-table">${table}</div>
          <p class="asset-cta">${escape(page.cta || '')}</p>
        </article>

        <article class="asset-panel asset-pane" data-asset-pane="faq">
          <div class="asset-meta">
            <span class="asset-status">Ready for page support</span>
            <button class="copy-button" type="button" data-copy="${escape((assets.faq || []).map((item) => `${item.question}\n${item.answer}`).join('\n\n'))}">Copy FAQ</button>
          </div>
          <h3>FAQ copy</h3>
          <div class="faq-list">${faq}</div>
        </article>

        <div class="asset-pane" data-asset-pane="schema">
          ${renderCodeBlock('Structured data JSON-LD', assets.schema_json_ld, 'html', 'schema-json-ld')}
        </div>

        <article class="asset-panel asset-pane" data-asset-pane="pitch">
          <div class="asset-meta">
            <span class="asset-status">Needs human review</span>
            <button class="copy-button" type="button" data-copy="${escape(`${assets.citation_pitch?.subject || 'Pitch'}\n\n${assets.citation_pitch?.body || ''}`)}">Copy pitch</button>
          </div>
          <h3>Citation pitch</h3>
          <p><strong>${escape(assets.citation_pitch?.subject || 'Pitch')}</strong></p>
          <p>${escape(assets.citation_pitch?.body || '')}</p>
          <h3>Editorial notes</h3>
          <ul>${(assets.editorial_notes || []).map((note) => `<li>${escape(note)}</li>`).join('')}</ul>
        </article>

        <div class="asset-pane" data-asset-pane="implementation">
          <div class="snippet-list">${snippets}</div>
        </div>
      `;
    }

    function renderCodeBlock(label, code, language = 'text', key = 'code') {
      const safeCode = String(code || '').trim();
      if (!safeCode) return '';
      return `
        <article class="code-panel">
          <div class="asset-meta">
            <span>${escape(label)}${language ? ` · ${escape(language)}` : ''}</span>
            <button class="copy-button" type="button" data-copy="${escape(safeCode)}" data-copy-key="${escape(key)}">Copy</button>
          </div>
          <pre><code>${escape(safeCode)}</code></pre>
        </article>
      `;
    }

    async function loadDashboard() {
      try {
        const resp = await fetch(`${apiUrl}/dashboard`, {
          headers: { Authorization: `Bearer ${token}` },
        });
        const data = await resp.json();
        if (resp.status === 401) {
          localStorage.removeItem('meridian_session');
          window.location.href = '/app/login';
          return;
        }
        if (!resp.ok) throw new Error(data.error || 'Could not load dashboard.');

        document.getElementById('loading').classList.add('hidden');
        if (!data.account) {
          document.getElementById('empty').classList.remove('hidden');
          return;
        }
        if (data.access_required) {
          text('empty-kicker', 'checkout required');
          text('empty-title', `Checkout is not complete for ${data.account.website || 'this monitor'}.`);
          text('empty-copy', 'Complete billing to generate the first AI Search brief, or choose another account with an active monitor.');
          document.getElementById('empty').classList.remove('hidden');
          return;
        }

        document.getElementById('dashboard').classList.remove('hidden');
        if (data.user?.is_admin) {
          document.getElementById('admin-panel').classList.remove('hidden');
          document.querySelector('#admin-plan-form select[name="plan"]').value = data.account.plan || 'monitor';
        }
        text('dashboard-title', data.account.company_name || data.account.website);
        text('dashboard-subtitle', `Monitoring ${data.account.website} for AI answer visibility, source gaps, and competitor drift.`);
        text('account-plan', data.account.plan_label || data.account.plan);
        text('account-status', data.account.status);
        text('account-domain', data.account.website);
        const seedPrompts = countList(data.brief?.prompts);
        const promptMapCount = data.report?.prompt_map?.length || seedPrompts;
        text('account-prompts', `${promptMapCount} prompt-map entries · ${seedPrompts} from inputs`);
        text('account-competitors', `${data.account.plan_features?.competitors || 0} tracked competitors`);

        renderReport(data.report);
      } catch (error) {
        document.getElementById('loading').innerHTML = `<div class="app-card"><h2>Could not load dashboard</h2><p class="app-muted">${error.message}</p></div>`;
      }
    }

    document.getElementById('run-report').addEventListener('click', async () => {
      const button = document.getElementById('run-report');
      const status = document.getElementById('run-status');
      button.disabled = true;
      button.textContent = 'Running...';
      status.textContent = 'Collecting page evidence and rebuilding the answer-market brief.';
      status.className = 'app-status ok visible';

      try {
        const resp = await fetch(`${apiUrl}/reports/run`, {
          method: 'POST',
          headers: { Authorization: `Bearer ${token}` },
        });
        const json = await resp.json();
        if (!resp.ok) throw new Error(json.error || 'Could not run report.');
        renderReport(json.report);
        status.textContent = 'Fresh brief generated.';
      } catch (error) {
        status.textContent = error.message || 'Could not run report.';
        status.className = 'app-status error visible';
      } finally {
        button.disabled = false;
        button.textContent = 'Run fresh brief';
      }
    });

    document.getElementById('export-report').addEventListener('click', () => {
      if (!currentReport) return;
      const blob = new Blob([JSON.stringify(currentReport, null, 2)], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const anchor = document.createElement('a');
      anchor.href = url;
      anchor.download = `meridian-answer-market-brief-${currentReport.website || 'report'}.json`;
      anchor.click();
      URL.revokeObjectURL(url);
    });

    document.getElementById('admin-plan-form').addEventListener('submit', async (event) => {
      event.preventDefault();
      const status = document.getElementById('admin-status');
      const plan = new FormData(event.currentTarget).get('plan');
      status.textContent = 'Switching preview tier...';
      status.className = 'app-status ok visible';
      try {
        const resp = await fetch(`${apiUrl}/admin/plan`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Authorization: `Bearer ${token}`,
          },
          body: JSON.stringify({ plan }),
        });
        const json = await resp.json();
        if (!resp.ok) throw new Error(json.error || 'Could not switch tier.');
        status.textContent = `Previewing ${json.account.plan_label}.`;
        await loadDashboard();
      } catch (error) {
        status.textContent = error.message || 'Could not switch tier.';
        status.className = 'app-status error visible';
      }
    });

    document.addEventListener('click', async (event) => {
      const button = event.target.closest('[data-copy]');
      if (!button) return;
      try {
        await navigator.clipboard.writeText(button.dataset.copy || '');
        const original = button.textContent;
        button.textContent = 'Copied';
        setTimeout(() => {
          button.textContent = original;
        }, 1200);
      } catch {
        button.textContent = 'Copy failed';
      }
    });

    document.addEventListener('click', (event) => {
      const tab = event.target.closest('[data-asset-tab]');
      if (!tab) return;
      const name = tab.dataset.assetTab;
      document.querySelectorAll('[data-asset-tab]').forEach((button) => {
        button.classList.toggle('active', button === tab);
      });
      document.querySelectorAll('[data-asset-pane]').forEach((pane) => {
        pane.classList.toggle('active', pane.dataset.assetPane === name);
      });
    });

    loadDashboard();
  </script>
</AppLayout>
