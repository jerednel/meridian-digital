---
import AppLayout from '../../layouts/AppLayout.astro';

const apiUrl = import.meta.env.PUBLIC_MERIDIAN_API_URL || 'http://127.0.0.1:3000';
---

<AppLayout title="Onboarding - Meridian" description="Set up your Meridian AI Search monitoring brief.">
  <div class="app-kicker">monitoring brief</div>
  <h1 class="app-title">Tune the buyer questions Meridian should monitor.</h1>
  <p class="app-subtitle">
    Give Meridian the category, competitors, and questions buyers actually ask before shortlisting vendors. Better inputs make the brief sharper.
  </p>
  <p class="app-muted">
    <span id="plan-limits">Loading your plan limits...</span>
    <span class="help-label">
      <button class="help-dot" type="button" aria-label="Plan limits explanation">i</button>
      <span class="help-tip" role="tooltip">Your plan limits how many custom questions and competitors you can enter. Meridian may expand your custom questions into a broader prompt map so it can cover common buyer research patterns.</span>
    </span>
  </p>

  <div class="app-grid">
    <section class="app-card">
      <form id="brief-form" class="app-form">
        <label>
          Company name
          <input name="company_name" autocomplete="organization" placeholder="Acme AI" />
        </label>
        <label>
          Domain to monitor
          <input name="website" type="url" required placeholder="https://company.com" />
        </label>
        <label>
          Category / buyer problem
          <input name="category" required placeholder="AI governance platform for financial services" />
          <span class="field-hint">Use the phrase a buyer would use, not your internal positioning. <span class="help-label"><button class="help-dot" type="button" aria-label="Category explanation">i</button><span class="help-tip" role="tooltip">This becomes the category Meridian tests in buyer questions. Good: "AI search visibility monitoring for B2B SaaS." Less useful: "next-generation answer intelligence platform."</span></span></span>
        </label>
        <label>
          Competitors or adjacent firms
          <textarea name="competitors" placeholder="List 3-5 competitors, one per line."></textarea>
          <span class="field-hint"><span id="competitor-count">0 competitors added.</span> <span class="help-label"><button class="help-dot" type="button" aria-label="Competitors input explanation">i</button><span class="help-tip" role="tooltip">These are the companies a buyer might compare you against. They do not have to be identical products; adjacent alternatives can still shape AI recommendations.</span></span></span>
        </label>
        <label>
          Buyer questions to track
          <textarea name="prompts" placeholder="What would a buyer ask ChatGPT, Perplexity, Gemini, or Google AI before comparing vendors?"></textarea>
          <span class="field-hint"><span id="prompt-count">0 custom buyer questions added.</span> <span class="help-label"><button class="help-dot" type="button" aria-label="Buyer questions explanation">i</button><span class="help-tip" role="tooltip">Write full questions, not keywords. Example: "Which AI search monitoring tools should a B2B SaaS team compare?" Meridian uses these as seeds and adds common buying questions around shortlists, risk, and procurement.</span></span></span>
        </label>
        <button class="app-button" type="submit">Save inputs and generate brief</button>
        <div id="status" class="app-status"></div>
      </form>
    </section>

    <aside class="app-card">
      <h2 class="help-label">
        <span>Strong examples</span>
        <button class="help-dot" type="button" aria-label="Strong examples explanation">i</button>
        <span class="help-tip" role="tooltip">These are examples of useful buyer questions because they match how prospects ask AI assistants for vendor recommendations, comparisons, and risk checks.</span>
      </h2>
      <ul>
        <li>Which AI search monitoring tools should a B2B SaaS team compare?</li>
        <li>What are the best alternatives to Otterly, Peec, and AthenaHQ?</li>
        <li>How should a marketing team measure visibility in ChatGPT and Perplexity?</li>
        <li>What implementation risks matter before buying an AI-search visibility tool?</li>
      </ul>
    </aside>
  </div>

  <script define:vars={{ apiUrl }}>
    const params = new URLSearchParams(window.location.search);
    const sessionId = params.get('session_id');
    const form = document.getElementById('brief-form');
    const status = document.getElementById('status');
    const planLimits = document.getElementById('plan-limits');
    const competitorCount = document.getElementById('competitor-count');
    const promptCount = document.getElementById('prompt-count');

    let token = localStorage.getItem('meridian_session');
    let maxCompetitors = 0;
    let maxPrompts = 0;

    const countLines = (value) => String(value || '').split(/\n|,/).map((item) => item.trim()).filter(Boolean).length;

    function updateCounts() {
      const competitors = countLines(form.competitors.value);
      const prompts = countLines(form.prompts.value);
      competitorCount.textContent = maxCompetitors ? `${competitors}/${maxCompetitors} competitors added.` : `${competitors} competitors added.`;
      promptCount.textContent = maxPrompts
        ? `${prompts}/${maxPrompts} custom buyer questions added. Meridian adds default shortlist, comparison, risk, and procurement prompts to the tracked map.`
        : `${prompts} custom buyer questions added.`;
      competitorCount.classList.toggle('warning', Boolean(maxCompetitors && competitors > maxCompetitors));
      promptCount.classList.toggle('warning', Boolean(maxPrompts && prompts > maxPrompts));
    }

    async function attachCheckoutSession() {
      if (!sessionId) return;
      const resp = await fetch(`${apiUrl}/checkout/session-login`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ session_id: sessionId }),
      });
      const json = await resp.json();
      if (!resp.ok) throw new Error(json.error || 'Could not open checkout session.');
      token = json.token;
      localStorage.setItem('meridian_session', token);
      if (json.account?.website) form.website.value = json.account.website;
      if (json.account?.company_name) form.company_name.value = json.account.company_name;
    }

    async function loadExisting() {
      if (!token) return;
      const resp = await fetch(`${apiUrl}/dashboard`, {
        headers: { Authorization: `Bearer ${token}` },
      });
      const data = await resp.json();
      if (!resp.ok) return;
      if (data.account?.website) form.website.value = data.account.website;
      if (data.account?.company_name) form.company_name.value = data.account.company_name;
      if (data.account?.plan_features) {
        maxCompetitors = data.account.plan_features.competitors || 0;
        maxPrompts = data.account.plan_features.prompts || 0;
        planLimits.textContent = `${data.account.plan_label || data.account.plan} includes up to ${data.account.plan_features.prompts} custom buyer questions and ${data.account.plan_features.competitors} competitors. Meridian may expand them into a broader tracked prompt map.`;
      }
      if (data.brief?.category) form.category.value = data.brief.category;
      if (data.brief?.competitors) form.competitors.value = data.brief.competitors;
      if (data.brief?.prompts) form.prompts.value = data.brief.prompts;
      updateCounts();
    }

    async function init() {
      try {
        await attachCheckoutSession();
        if (!token) {
          window.location.href = '/app/login';
          return;
        }
        await loadExisting();
      } catch (error) {
        status.textContent = error.message;
        status.className = 'app-status error visible';
      }
    }

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      status.className = 'app-status';
      const data = Object.fromEntries(new FormData(form).entries());

      try {
        const resp = await fetch(`${apiUrl}/onboarding`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Authorization: `Bearer ${token}`,
          },
          body: JSON.stringify(data),
        });
        const json = await resp.json();
        if (!resp.ok) throw new Error(json.error || 'Could not save brief.');
        status.textContent = 'First brief generated. Opening dashboard...';
        status.className = 'app-status ok visible';
        window.setTimeout(() => { window.location.href = '/app'; }, 700);
      } catch (error) {
        status.textContent = error.message || 'Could not save brief.';
        status.className = 'app-status error visible';
      }
    });

    form.competitors.addEventListener('input', updateCounts);
    form.prompts.addEventListener('input', updateCounts);

    init();
  </script>
</AppLayout>
